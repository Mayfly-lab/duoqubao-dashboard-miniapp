page {
  background-color: #0f1729;
  color: #eef2fb;
  font-family: -apple-system, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
}

.container {
  padding: 24rpx 28rpx 60rpx;
}

/* 卡片 */
.card {
  background: #19233c;
  border: 1rpx solid #2c3a5c;
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #eef2fb;
  margin-bottom: 8rpx;
}

.card-hint {
  font-size: 22rpx;
  color: #94a3c4;
  margin-bottom: 28rpx;
}

/* 演示数据横幅（mock 阶段全局提示） */
.demo-banner {
  background: rgba(245,165,36,.12);
  border: 1rpx solid rgba(245,165,36,.4);
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
  font-size: 22rpx;
  color: #f5a524;
}

/* 内联 mock 标记：用于连真实数据源都还没有的字段 */
.mock-tag {
  display: inline-block;
  font-size: 18rpx;
  color: #f06292;
  background: rgba(240,98,146,.15);
  border-radius: 6rpx;
  padding: 0 8rpx;
  margin-left: 8rpx;
  vertical-align: middle;
}

/* 颜色变量（用 class 模拟）*/
.text-blue   { color: #5b8cff; }
.text-green  { color: #22c4a8; }
.text-yellow { color: #f5a524; }
.text-purple { color: #8b5cf6; }
.text-pink   { color: #f06292; }
.text-muted  { color: #94a3c4; }
.text-dim    { color: #6b7280; }
