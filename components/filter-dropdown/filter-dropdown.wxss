.fd { position: relative; }
.fd-btn {
  font-size: 22rpx; color: #6b7891;
  border: 1rpx solid #edf0f5; border-radius: 10rpx;
  padding: 8rpx 18rpx; background: #eef1f6;
}
.fd-arrow { font-size: 18rpx; }
.fd-mask {
  position: fixed; left: 0; top: 0; right: 0; bottom: 0; z-index: 9;
}
.fd-menu {
  position: absolute; right: 0; top: 100%; margin-top: 10rpx;
  background: #1f2c4a; border: 1rpx solid #edf0f5; border-radius: 14rpx;
  z-index: 10; min-width: 180rpx; overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,.35);
}
.fd-item { font-size: 24rpx; padding: 18rpx 28rpx; color: #cdd6ec; }
.fd-item-on { color: #2b6cff; background: rgba(43,108,255,.10); }
