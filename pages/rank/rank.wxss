.rank-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.rank-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 16rpx;
  border-radius: 14rpx;
  margin-bottom: 4rpx;
  background: #f3f6fc;
}
.rank-row:active { background: #eef1f6; }

.rank-pos {
  width: 40rpx;
  text-align: center;
  font-size: 24rpx;
  color: #6b7891;
  flex-shrink: 0;
}
.top1 .rank-pos { color: #ffd24a; font-weight: 700; font-size: 28rpx; }
.top2 .rank-pos { color: #cdd6e8; font-weight: 700; }
.top3 .rank-pos { color: #e0915a; font-weight: 700; }

.rank-info {
  display: flex;
  align-items: center;
  gap: 10rpx;
  width: 160rpx;
  flex-shrink: 0;
}
.rank-name {
  font-size: 26rpx;
  color: #1f2a3c;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.rank-dept {
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}
.dept-duo { background: rgba(43,108,255,.14); color: #9fbcff; }
.dept-gez { background: rgba(34,196,168,.18); color: #5fe0c8; }

.rank-bar-wrap {
  flex: 1;
  height: 12rpx;
  background: #ffffff;
  border-radius: 6rpx;
  overflow: hidden;
}
.rank-bar {
  height: 100%;
  background: linear-gradient(90deg, #2b6cff, #7c5cff);
  border-radius: 6rpx;
  min-width: 4rpx;
}
.top1 .rank-bar { background: linear-gradient(90deg, #ffd24a, #f0a020); }

.rank-stat {
  flex-shrink: 0;
  text-align: right;
}
.rank-msgs {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2a3c;
}
.rank-days {
  font-size: 22rpx;
  color: #6b7891;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(8, 12, 22, 0.75);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 100;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s;
}
.modal-mask.show {
  opacity: 1;
  pointer-events: auto;
}
.modal-box {
  background: #f3f6fc;
  border-radius: 32rpx 32rpx 0 0;
  width: 100%;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}
.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 36rpx 20rpx;
  border-bottom: 1rpx solid #edf0f5;
}
.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2a3c;
}
.modal-close {
  font-size: 48rpx;
  color: #6b7891;
  line-height: 1;
  padding: 0 8rpx;
}
.modal-body {
  flex: 1;
  overflow: hidden;
  padding: 16rpx 36rpx 32rpx;
}
.msg-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #1e2d4a;
  display: flex;
  gap: 20rpx;
}
.msg-item:last-child { border-bottom: none; }
.msg-date {
  font-size: 22rpx;
  color: #2b6cff;
  flex-shrink: 0;
  padding-top: 4rpx;
  width: 100rpx;
}
.msg-text {
  font-size: 26rpx;
  color: #dbe3f4;
  line-height: 1.6;
}
