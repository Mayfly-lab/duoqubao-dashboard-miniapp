<view class="container">
  <view wx:if="{{loading}}" class="card">加载中…</view>
  <view wx:if="{{error}}" class="card" style="color:#f06292">{{error}}</view>

  <block wx:if="{{!loading && !error}}">
  <!-- 类整体 + 回款 -->
  <view class="card">
    <view class="cat-title">{{line}}<text class="cat-tag">{{models.length}} 型号</text></view>
    <view class="ph-grid">
      <view class="ph-item"><view class="ph-num text-blue">{{kpi.salesText}}</view><view class="ph-lab">销售额</view></view>
      <view class="ph-item"><view class="ph-num {{kpi.loss ? 'text-pink' : 'text-green'}}">{{kpi.profitText}}</view><view class="ph-lab">毛利 {{kpi.marginPct}}%</view></view>
      <view class="ph-item"><view class="ph-num text-green">{{kpi.realizedText}}</view><view class="ph-lab">已到账</view></view>
      <view class="ph-item"><view class="ph-num text-yellow">{{kpi.pendingText}}</view><view class="ph-lab">待回款</view></view>
    </view>
    <view class="card-hint">金额均为人民币（领星美元 × FX 6.8），与下方回本/采购同币种</view>
  </view>

  <!-- L0 采购未归集:大杂烩/特殊线,金蝶按产品名记账拆不到本类,不显示误导的回本% -->
  <view wx:if="{{level0 && level0.procMissing}}" class="card">
    <view class="card-title">回本进度 · 待补</view>
    <view class="card-hint">本类采购未归集——属大杂烩/特殊线（长尾/其他/种子链接等），金蝶按具体产品名记账，无法按本类名匹配采购，故回本暂不计算。回款（已到账+在途）{{level0.backText}} 仍可见于上方 KPI。</view>
  </view>

  <!-- L0 双进度条 -->
  <view wx:if="{{level0 && !level0.procMissing}}" class="card">
    <view class="card-title">回本进度 · 锁定 {{level0.lockPct}}%</view>
    <view class="card-hint">上=全投入 {{level0.investText}} / 下=回款 {{level0.backText}}（已到账+在途·同比例尺·¥）· 采购取活跃代 {{level0.buyYear}} 年（治款混·与回款同代）· 头程按台数估 · opex 类聚合偏漏</view>
    <view class="prog">
      <view wx:for="{{level0.investSegs}}" wx:key="label" class="prog-seg {{item.cls}}" style="width:{{item.w}}%"></view>
    </view>
    <view class="prog-legend">
      <view wx:for="{{level0.investSegs}}" wx:key="label" class="lg"><text class="dot {{item.cls}}"></text>{{item.label}} {{item.val}}</view>
    </view>
    <view class="prog">
      <view wx:for="{{level0.backSegs}}" wx:key="label" class="prog-seg {{item.cls}}" style="width:{{item.w}}%"></view>
    </view>
    <view class="prog-legend">
      <view wx:for="{{level0.backSegs}}" wx:key="label" class="lg"><text class="dot {{item.cls}}"></text>{{item.label}} {{item.val}}</view>
    </view>
    <view class="future-line">账期红利：欠厂 {{level0.owe}} 未付 · 可用回款滚动付尾款</view>
  </view>

  <!-- L1 四问 -->
  <view wx:if="{{four && !level0.procMissing}}" class="card">
    <view class="card-title">四问</view>
    <view class="q-grid">
      <view class="q-card">
        <view class="q-t">① 钱→货</view>
        <view class="q-r">采购 {{four.q1.buy}} · {{four.q1.qty}} 台</view>
        <view class="q-r">已付 {{four.q1.paid}} · 欠厂 <text class="text-yellow">{{four.q1.owe}}</text></view>
      </view>
      <view class="q-card">
        <view class="q-t">② 货→费用</view>
        <view class="q-r">头程 {{four.q2.freight}}（估）</view>
        <view class="q-r">运营 {{four.q2.opex}} · 平台费 {{four.q2.plat}}</view>
      </view>
      <view class="q-card">
        <view class="q-t">③ 卖→回款</view>
        <view class="q-r">销售额 {{four.q3.sales}}</view>
        <view class="q-r">已到账 <text class="text-green">{{four.q3.realized}}</text></view>
      </view>
      <view class="q-card">
        <view class="q-t">④ 收回 vs 付出</view>
        <view class="q-r">投入 {{four.q4.invest}} · 回款 {{four.q4.locked}}</view>
        <view class="q-r">盈余 <text class="{{four.q4.overPos ? 'text-green' : 'text-pink'}}">{{four.q4.over}}</text></view>
      </view>
    </view>
  </view>

  <!-- 弹药 -->
  <view wx:if="{{inventory}}" class="card">
    <view class="card-title">库存状况</view>
    <view class="ph-grid">
      <view class="ph-item"><view class="ph-num">{{inventory.xianhuo}}</view><view class="ph-lab">现货</view></view>
      <view class="ph-item"><view class="ph-num">{{inventory.zaitu}}</view><view class="ph-lab">在途</view></view>
    </view>
  </view>

  <!-- 回款时间轴 -->
  <view wx:if="{{timeline.length}}" class="card">
    <view class="card-title">回款时间轴（月度到账 · ¥）</view>
    <view class="card-hint">柱高=当月到账额，红=负值（退款&gt;订单）</view>
    <view wx:for="{{timeline}}" wx:key="ym" class="tl-row">
      <text class="tl-ym">{{item.ym}}</text>
      <view class="tl-bar2"><view class="tl-fill {{item.neg ? 'tl-fill-neg' : ''}}" style="width:{{item.w}}%"></view></view>
      <text class="tl-amt {{item.neg ? 'text-pink' : 'text-green'}}">{{item.valShort}}</text>
    </view>
  </view>

  <!-- 广告 -->
  <view wx:if="{{ads}}" class="card">
    <view class="card-title">广告效率</view>
    <view class="ph-grid">
      <view class="ph-item"><view class="ph-num">{{ads.spendText}}</view><view class="ph-lab">广告花费</view></view>
      <view class="ph-item"><view class="ph-num text-green">{{ads.revText}}</view><view class="ph-lab">广告销售</view></view>
      <view class="ph-item"><view class="ph-num text-purple">{{ads.acos}}%</view><view class="ph-lab">ACOS</view></view>
    </view>
  </view>

  <!-- 退款 -->
  <view wx:if="{{refund}}" class="card">
    <view class="card-title">退款</view>
    <view class="ph-grid">
      <view class="ph-item"><view class="ph-num text-pink">{{refund.rate}}%</view><view class="ph-lab">退款率</view></view>
      <view class="ph-item"><view class="ph-num">{{refund.returns}}</view><view class="ph-lab">退货量</view></view>
      <view class="ph-item"><view class="ph-num text-pink">{{refund.amtText}}</view><view class="ph-lab">退款额</view></view>
    </view>
  </view>

  <!-- 亚马逊结算视角:到手 = 销售 − 各项(对齐 mockup) -->
  <view wx:if="{{settle}}" class="card">
    <view class="card-title">结算视角 · 到手 {{settle.netText}}（{{settle.netPct}}%）</view>
    <view class="card-hint">全期·USD ⚠️ 平台结算后 ≠ 毛利（未扣采购成本 COGS,口径不同于上方 KPI 毛利）</view>
    <view class="settle-row settle-top">
      <view class="settle-name">销售额</view>
      <view class="settle-val text-green">{{settle.salesText}}</view>
    </view>
    <view wx:for="{{settle.items}}" wx:key="label" class="settle-row">
      <view class="settle-name">− {{item.label}}</view>
      <view class="settle-bar"><view class="settle-bar-fill" style="width:{{item.w}}%"></view></view>
      <view class="settle-val text-pink">{{item.valText}}</view>
    </view>
    <view class="settle-row settle-net">
      <view class="settle-name">= 到手</view>
      <view class="settle-val {{settle.netLoss ? 'text-pink' : 'text-green'}}">{{settle.netText}}</view>
    </view>
  </view>

  <!-- 费用扣除 -->
  <view wx:if="{{fees.length}}" class="card">
    <view class="card-title">费用扣除（平台 · 美元结算 $）</view>
    <view wx:for="{{fees}}" wx:key="description" class="fee-row">
      <view class="fee-name">{{item.description}}</view>
      <view class="fee-bar"><view class="fee-bar-fill" style="width:{{item.barWidth}}%"></view></view>
      <view class="fee-val">{{item.costText}}</view>
    </view>
  </view>

  <!-- 品质星级 -->
  <view wx:if="{{stars.length}}" class="card">
    <view class="card-title">质量 · 星级（by ASIN）</view>
    <view wx:for="{{stars}}" wx:key="asin" class="star-row">
      <view class="star-asin">{{item.asin}}<text class="star-rev">{{item.reviews}} 评论</text></view>
      <view class="{{item.low ? 'text-pink' : 'text-green'}}">★ {{item.star}}</view>
    </view>
  </view>

  <!-- 运营费用 / 费用动作 -->
  <view wx:if="{{opex.length}}" class="card">
    <view class="card-title">运营费用 · 费用动作（¥）</view>
    <view class="card-hint">测评=刷单/测评 · 按类归集（摘要匹配，型号级会漏）</view>
    <view wx:for="{{opex}}" wx:key="category" class="fee-row">
      <view class="fee-name">{{item.category}}</view>
      <view class="fee-bar"><view class="fee-bar-fill opex-fill" style="width:{{item.barWidth}}%"></view></view>
      <view class="fee-val opex-val">{{item.costText}}</view>
    </view>
  </view>

  <!-- 型号列表 -->
  <view class="card">
    <view class="card-title">型号（{{models.length}}）</view>
    <view class="card-hint">👆 点任意型号 → 进入该型号详细看板（未铺货款仅采购、暂无销售看板）</view>
    <view
      wx:for="{{models}}" wx:key="name"
      class="cat {{item.unstocked ? 'cat-unstocked' : 'cat-click'}} {{item.loss ? 'cat-loss' : ''}}"
      data-name="{{item.name}}" bindtap="{{item.unstocked ? '' : 'onModelTap'}}">
      <view class="cat-head">
        <view class="cat-name">{{item.name}}<text wx:if="{{item.unstocked}}" class="badge-unstocked">未铺货</text></view>
        <view class="cat-right">
          <view class="cat-sales">{{item.salesText}}</view>
          <view wx:if="{{!item.unstocked}}" class="cat-sub {{item.loss ? 'text-pink' : 'text-green'}}">毛利 {{item.profitText}} · {{item.marginPct}}%</view>
          <view wx:else class="cat-sub text-mut">采购 {{item.buyText}} · 待铺货</view>
        </view>
        <text class="go-arrow">›</text>
      </view>
      <view class="cat-bar"><view class="cat-bar-fill" style="width:{{item.barWidth}}%"></view></view>
    </view>
    <view wx:if="{{unmappedText}}" class="future-line">类级未拆采购 {{unmappedText}}（金蝶按笼统名记账，拆不到具体型号）· Σ型号采购 + 未拆 = 类采购</view>
  </view>

  <view class="foot-note">数据：领星 + 金蝶财务（duoqubao-api 静态快照 {{generatedAt}}）· 销售/回款全期（领星 2025-06 硬地板≈当年款）· 采购取活跃代年份（治款混·与回款同代）· opex 类聚合（型号变体偏漏）</view>
  </block>
</view>
