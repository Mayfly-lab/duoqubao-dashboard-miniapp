.cat-title { font-size: 34rpx; font-weight: 700; color: #eef2fb; margin-bottom: 24rpx; }
.cat-tag {
  font-size: 20rpx; color: #94a3c4;
  border: 1rpx solid #2c3a5c; border-radius: 8rpx;
  padding: 2rpx 12rpx; margin-left: 14rpx; vertical-align: middle;
}

/* 小指标网格(类KPI / 广告 / 退款 / 弹药) */
.ph-grid { display: flex; flex-wrap: wrap; margin: -7rpx; }
.ph-item {
  flex: 1 1 140rpx; min-width: 140rpx; margin: 7rpx; box-sizing: border-box;
  background: #0f1729; border: 1rpx solid #2c3a5c;
  border-radius: 14rpx; padding: 20rpx;
}
.ph-num { font-size: 34rpx; font-weight: 700; color: #eef2fb; }
.ph-lab { font-size: 20rpx; color: #94a3c4; margin-top: 6rpx; }

/* 时间轴(横向滚动·标数字) */
/* 时间轴:横向条形列表(每月一行) */
.tl-row { display: flex; align-items: center; margin-bottom: 12rpx; }
.tl-ym { width: 88rpx; font-size: 20rpx; color: #94a3c4; flex-shrink: 0; }
.tl-bar2 { flex: 1; height: 16rpx; background: #0f1729; border-radius: 8rpx; margin: 0 16rpx; overflow: hidden; }
.tl-fill { height: 100%; background: linear-gradient(90deg, #22c4a8, #5b8cff); border-radius: 8rpx; }
.tl-fill-neg { background: #f06292; }
.tl-amt { width: 110rpx; text-align: right; font-size: 20rpx; flex-shrink: 0; }

/* 横条(费用 / 运营费用) */
.fee-row { display: flex; align-items: center; margin-bottom: 14rpx; }
.fee-name { width: 200rpx; font-size: 22rpx; color: #cbd5e1; }
.fee-bar { flex: 1; height: 12rpx; background: #0f1729; border-radius: 6rpx; margin: 0 16rpx; overflow: hidden; }
.fee-bar-fill { height: 100%; background: #f5a524; border-radius: 6rpx; }
.fee-val { width: 150rpx; text-align: right; font-size: 22rpx; color: #f5a524; }
.opex-fill { background: #8b5cf6; }
.opex-val { color: #8b5cf6; }

/* 星级 */
.star-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 14rpx 0; border-top: 1rpx solid #2c3a5c;
}
.star-row:first-child { border-top: none; }
.star-asin { font-size: 24rpx; color: #eef2fb; }
.star-rev { font-size: 20rpx; color: #6b7280; margin-left: 12rpx; }

/* 型号行 */
.cat { padding: 24rpx 0; border-bottom: 1rpx solid #2c3a5c; }
.cat:last-child { border-bottom: none; }
.cat-head { display: flex; justify-content: space-between; align-items: center; }
.cat-name { font-size: 30rpx; font-weight: 600; color: #eef2fb; flex: 1; }
/* 可点击引导 */
.cat-click { padding: 24rpx 20rpx; margin: 0 -20rpx; border-radius: 12rpx; transition: background .15s; }
.cat-click:active { background: rgba(91,140,255,.12); }
.go-arrow { font-size: 44rpx; color: #5b8cff; margin-left: 16rpx; flex-shrink: 0; line-height: 1; }
.cat-right { text-align: right; }
.cat-sales { font-size: 30rpx; font-weight: 600; color: #eef2fb; }
.cat-sub { font-size: 22rpx; margin-top: 6rpx; }
.cat-loss .cat-name { color: #f06292; }
.cat-bar { height: 8rpx; background: #0f1729; border-radius: 4rpx; margin-top: 16rpx; overflow: hidden; }
.cat-bar-fill { height: 100%; background: #5b8cff; border-radius: 4rpx; }
.cat-loss .cat-bar-fill { background: #f06292; }

/* L0 双进度条 */
.prog {
  display: flex; height: 28rpx; background: #0f1729;
  border-radius: 14rpx; overflow: hidden; margin-top: 20rpx;
}
.prog-seg { height: 100%; }
.seg-buy { background: #5b8cff; }
.seg-freight { background: #7c9cff; }
.seg-opex { background: #8b5cf6; }
.seg-realized { background: #22c4a8; }
.seg-pending { background: #f5a524; }
.prog-legend { display: flex; flex-wrap: wrap; gap: 8rpx 24rpx; margin-top: 12rpx; }
.lg { font-size: 20rpx; color: #94a3c4; }
.dot { display: inline-block; width: 16rpx; height: 16rpx; border-radius: 4rpx; margin-right: 8rpx; vertical-align: middle; }

/* L1 四问 */
.q-grid { display: flex; flex-wrap: wrap; justify-content: space-between; }
.q-card {
  width: 48%; margin-bottom: 16rpx; box-sizing: border-box;
  background: #0f1729; border: 1rpx solid #2c3a5c; border-radius: 16rpx; padding: 20rpx;
}
.q-t { font-size: 24rpx; font-weight: 600; color: #eef2fb; margin-bottom: 12rpx; }
.q-r { font-size: 22rpx; color: #cbd5e1; margin-top: 6rpx; }

.foot-note { text-align: center; font-size: 20rpx; color: #6b7280; margin-top: 32rpx; }

/* 未来现金提示行(不进回收率) */
.future-line { margin-top: 14rpx; font-size: 22rpx; color: #8a93a0; line-height: 1.5; }

/* 回本进度卡重设计 */
.rb-head { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20rpx; }
.rb-pct { font-size: 56rpx; font-weight: 700; color: #5b8cff; line-height: 1; }
.rb-hint { font-size: 18rpx; color: #6b7280; margin-top: 6rpx; }
.rb-row-label { font-size: 22rpx; color: #94a3c4; margin-top: 4rpx; }
.lg-val { color: #eef2fb; }
.rb-owe { margin-top: 18rpx; font-size: 22rpx; background: #0f1729; border-radius: 10rpx; padding: 14rpx 16rpx; line-height: 1.6; }
.rb-owe-row { display: flex; align-items: center; flex-wrap: wrap; color: #eef2fb; }
.rb-owe-note { font-size: 20rpx; color: #6b7280; margin-top: 6rpx; }

/* 结算视角:到手 = 销售 − 各项 */
.settle-row { display: flex; align-items: center; gap: 14rpx; padding: 10rpx 0; }
.settle-name { width: 150rpx; font-size: 26rpx; color: #c2c9d2; flex-shrink: 0; }
.settle-bar { flex: 1; height: 14rpx; background: rgba(255,255,255,.06); border-radius: 7rpx; overflow: hidden; }
.settle-bar-fill { height: 100%; background: #f06292; border-radius: 7rpx; }
.settle-val { width: 150rpx; text-align: right; font-size: 26rpx; flex-shrink: 0; }
.settle-top { border-bottom: 1rpx solid rgba(255,255,255,.08); }
.settle-net { margin-top: 6rpx; border-top: 1rpx solid rgba(255,255,255,.12); font-weight: 700; }
.settle-net .settle-name, .settle-net .settle-val { font-size: 30rpx; }

/* 未铺货型号:有采购无销售 */
.badge-unstocked { display:inline-block; margin-left:10rpx; padding:2rpx 10rpx; font-size:20rpx; color:#b08900; background:rgba(245,165,36,.15); border-radius:6rpx; vertical-align:middle; }
.cat-unstocked { opacity:.72; }
.text-mut { color:#8a93a0; }
