.hero {
  padding: 24rpx 0 40rpx;
}
.hero-label {
  font-size: 22rpx;
  color: #18b888;
  font-weight: 600;
  letter-spacing: 2rpx;
  margin-bottom: 10rpx;
}
.hero-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1f2a3c;
  line-height: 1.3;
}
.hero-sub {
  font-size: 24rpx;
  color: #6b7891;
  margin-top: 12rpx;
}

/* 问题-解法卡片 */
.prob-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 48rpx;
}

.prob-card {
  background: #f3f6fc;
  border: 1rpx solid #edf0f5;
  border-radius: 20rpx;
  overflow: hidden;
}
.prob-card.expanded {
  border-color: #18b888;
}

.prob-header {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 28rpx 24rpx;
}
.prob-icon {
  font-size: 40rpx;
  flex-shrink: 0;
  line-height: 1;
  padding-top: 6rpx;
}
.prob-body { flex: 1; }
.prob-problem {
  font-size: 28rpx;
  font-weight: 600;
  color: #6b7891;
  margin-bottom: 10rpx;
  line-height: 1.4;
}
.prob-solution {
  font-size: 28rpx;
  color: #1f2a3c;
  line-height: 1.6;
}
.prob-arrow {
  font-size: 44rpx;
  color: #6b7891;
  flex-shrink: 0;
  transition: transform 0.2s;
  padding-top: 2rpx;
}
.prob-arrow.open { transform: rotate(90deg); }

/* 展开详情 */
.prob-detail {
  padding: 0 24rpx 28rpx 84rpx;
}
.detail-example {
  background: #111927;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}
.detail-example-label {
  font-size: 20rpx;
  color: #9aa6bc;
  margin-bottom: 8rpx;
}
.detail-example-text {
  font-size: 26rpx;
  color: #2b6cff;
  line-height: 1.6;
  font-style: italic;
}
.detail-proof {
  font-size: 22rpx;
  color: #6b7891;
  line-height: 1.5;
}

/* 指令速查 */
.section-divider {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}
.divider-line {
  flex: 1;
  height: 1rpx;
  background: #edf0f5;
}
.divider-text {
  font-size: 24rpx;
  color: #9aa6bc;
  flex-shrink: 0;
}
.divider-hint {
  font-size: 22rpx;
  color: #9aa6bc;
  margin-bottom: 24rpx;
  text-align: center;
}

.cmd-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}
.cmd-item {
  background: #f3f6fc;
  border: 1rpx solid #edf0f5;
  border-radius: 14rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.cmd-code {
  font-size: 30rpx;
  font-weight: 700;
  color: #2b6cff;
  font-family: monospace;
}
.cmd-desc {
  font-size: 22rpx;
  color: #6b7891;
  line-height: 1.4;
}
