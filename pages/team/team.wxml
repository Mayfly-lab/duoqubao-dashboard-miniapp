<view class="container">

  <view class="demo-banner">⚠️ 演示数据：团队看板依赖员工归属、组织架构、动作数据，目前<text class="mock-tag">mock</text>这三类数据源均未建立，整页为占位。</view>

  <!-- 角色切换 -->
  <view class="role-bar">
    <view
      wx:for="{{roleOrder}}" wx:key="*this"
      class="role-tab {{role === item ? 'role-tab-on' : ''}}"
      data-role="{{item}}" bindtap="onRoleTap">
      {{roleLabel[item]}}
    </view>
  </view>
  <view class="role-hint">当前视角：{{roleName}} · 按毛利贡献排序</view>

  <view class="card">
    <view class="card-title">员工经营（{{employees.length}} 人）<text class="mock-tag">mock</text></view>
    <view class="card-hint">动作 vs 收益：看每个人的动作有没有带来收益 · 红色为负贡献</view>

    <view wx:for="{{employees}}" wx:key="name" class="emp {{item.loss ? 'emp-loss' : ''}}">
      <view class="emp-head">
        <view class="emp-left">
          <view class="emp-name">{{item.name}}<text class="emp-team">{{item.team}}</text></view>
          <view class="emp-meta">负责：{{item.projectsText}}</view>
        </view>
        <view class="emp-right">
          <view class="emp-contrib {{item.loss ? 'text-pink' : 'text-green'}}">{{item.contribText}}</view>
          <view class="emp-sub">毛利贡献</view>
        </view>
      </view>

      <view class="emp-bar"><view class="emp-bar-fill" style="width:{{item.barWidth}}%"></view></view>

      <view class="emp-stats">
        <view class="stat"><text class="stat-num">{{item.actions}}</text><text class="stat-lab">近30天动作</text></view>
        <view class="stat"><text class="stat-num text-yellow">{{item.perAction}}</text><text class="stat-lab">每动作产出</text></view>
        <view class="stat"><text class="stat-num text-purple">{{item.adCostText}}</text><text class="stat-lab">广告花费</text></view>
      </view>
    </view>
  </view>

  <view class="foot-note">UI 占位 · 员工归属/动作数据接入后由云函数按角色下发</view>
</view>
