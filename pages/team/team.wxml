<view class="container">

  <view class="demo-banner">团队 = 各产品类下的 <text class="text-green">负责人 / 参与人</text>（registry 归属）· 组织职责视图，<text class="text-blue">不挂个人盈亏/费用</text>（opex 无产品列·无人字段，拆不到个人）。</view>

  <view wx:if="{{loading}}" class="card">加载中…</view>
  <view wx:if="{{error}}" class="card" style="color:#f06292">{{error}}</view>

  <block wx:if="{{!loading && !error}}">
  <view class="role-hint">按产品类看人员 · 数据快照 {{generatedAt}} · 全期累计</view>

  <!-- 时间轴日期范围过滤 -->
  <view class="date-filter-row">
    <text class="date-filter-label">时间轴范围</text>
    <picker mode="selector" range="{{allMonths}}" bindchange="onStartPick">
      <view class="date-pick-btn">{{startYm || '起始月 ▾'}}</view>
    </picker>
    <text class="date-sep">—</text>
    <picker mode="selector" range="{{allMonths}}" bindchange="onEndPick">
      <view class="date-pick-btn">{{endYm || '结束月 ▾'}}</view>
    </picker>
    <view wx:if="{{startYm || endYm}}" class="date-clear" bindtap="onClearFilter">× 清除</view>
  </view>

  <view wx:for="{{categories}}" wx:key="line" class="card">
    <!-- 类 -->
    <view class="cat-head" data-line="{{item.line}}" bindtap="onCatTap">
      <view class="cat-left">
        <view class="cat-name">{{item.line}}<text class="cat-arrow">{{item.expanded ? ' ▲' : ' ▼'}}</text></view>
        <view class="cat-meta">{{item.peopleCount}} 人</view>
      </view>
      <view class="cat-right">
        <view class="cat-sales">{{item.salesText}}</view>
        <view class="cat-sub {{item.loss ? 'text-pink' : 'text-green'}}">毛利 {{item.profitText}} · {{item.marginPct}}%</view>
      </view>
    </view>
    <view class="cat-bar"><view class="cat-bar-fill" style="width:{{item.barWidth}}%"></view></view>

    <!-- 类下人员 -->
    <view wx:if="{{item.expanded}}" class="people">
      <view wx:for="{{item.people}}" wx:for-item="pe" wx:key="name" class="person">
        <view class="person-head" data-name="{{pe.name}}" bindtap="onPersonTap">
          <view class="person-left">
            <view class="person-name">{{pe.name}}<text class="person-arrow">{{pe.expanded ? ' ▲' : ' ▼'}}</text></view>
            <view class="person-badges">
              <text class="badge badge-own">主责 {{pe.ownCount}}</text>
              <text wx:if="{{pe.joinCount}}" class="badge badge-join">参与 {{pe.joinCount}}</text>
            </view>
          </view>
        </view>

        <!-- 个人:产品清单 + 回款汇总 + 月度生命周期 -->
        <view wx:if="{{pe.expanded}}" class="person-detail">
          <!-- 主责产品回款汇总 -->
          <view wx:if="{{pe.hasPayback}}" class="pe-pb-row">
            <text class="pe-pb-label">{{pe.filterActive ? '区间回款' : '主责回款'}}</text>
            <text class="text-green">到账 {{pe.personRealized}}</text>
            <block wx:if="{{!pe.filterActive}}">
              <text class="text-muted"> · 在途 </text><text class="text-blue">{{pe.personPending}}</text>
            </block>
          </view>
          <!-- 产品列表（可展开生命周期） -->
          <view wx:for="{{pe.products}}" wx:for-item="p" wx:key="name" class="prod-item">
            <view class="prod-row" data-key="{{p.key}}" bindtap="onProductTap">
              <text class="prod-name">{{p.name}}</text>
              <view class="prod-row-right">
                <text class="prod-role {{p.isOwner ? 'role-own' : 'role-join'}}">{{p.role}}</text>
                <text wx:if="{{p.hasTimeline || p.hasPayback}}" class="prod-expand-arrow">{{p.expanded ? '▲' : '▼'}}</text>
              </view>
            </view>
            <!-- 产品展开：回款明细 + 月度时间轴 -->
            <view wx:if="{{p.expanded && (p.hasPayback || p.hasTimeline)}}" class="prod-lifecycle">
              <view wx:if="{{p.hasPayback}}" class="lc-pb-row">
                <text class="lc-pb-item"><text class="text-muted">到账 </text><text class="text-green">{{p.realized}}</text></text>
                <text class="lc-pb-sep"> · </text>
                <text class="lc-pb-item"><text class="text-muted">在途 </text><text class="text-blue">{{p.pending}}</text></text>
                <text wx:if="{{p.hasLocked}}" class="lc-pb-sep"> · </text>
                <text wx:if="{{p.hasLocked}}" class="lc-pb-item"><text class="text-muted">锁定 </text><text class="text-yellow">{{p.locked}}</text></text>
              </view>
              <view wx:if="{{p.hasTimeline}}">
                <view class="lc-chart-title">月度回款时间轴</view>
                <view wx:if="{{p.timeline.length === 0}}" class="lc-no-data">该时间段内暂无数据</view>
                <scroll-view wx:else scroll-x class="lc-chart">
                  <view class="lc-bars">
                    <view wx:for="{{p.timeline}}" wx:for-item="bar" wx:key="ym" class="lc-bar-col">
                      <view class="lc-pos-zone">
                        <view wx:if="{{bar.posH > 0}}" class="lc-bar-pos" style="height:{{bar.posH}}rpx"></view>
                      </view>
                      <view class="lc-zero"></view>
                      <view class="lc-neg-zone">
                        <view wx:if="{{bar.negH > 0}}" class="lc-bar-neg" style="height:{{bar.negH}}rpx"></view>
                      </view>
                      <view class="lc-bar-label">{{bar.label}}</view>
                    </view>
                  </view>
                </scroll-view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
  </block>

  <view class="foot-note">数据：领星销售（duoqubao-api 快照 {{generatedAt}}）· 团队按产品类组织 · 个人回款 = 主责产品 payback 汇总 · 费用(opex)无产品列/无人字段，仅在公司·类级展示</view>
</view>
