<view class="container">

  <view class="demo-banner">团队 = 各产品类下的 <text class="text-green">负责人 / 参与人</text>（registry 归属）· 组织职责视图，<text class="text-blue">不挂个人盈亏/费用</text>（opex 无产品列·无人字段，拆不到个人）。</view>

  <view wx:if="{{loading}}" class="card">加载中…</view>
  <view wx:if="{{error}}" class="card" style="color:#f5455c">{{error}}</view>

  <block wx:if="{{!loading && !error}}">
  <view class="role-hint">按产品类看人员 · 数据快照 {{generatedAt}} · 无筛选=全期</view>

  <!-- 时间轴日期范围过滤 -->
  <view class="date-filter-row">
    <text class="date-filter-label">月份范围</text>
    <picker mode="selector" range="{{allMonths}}" bindchange="onStartPick">
      <view class="date-pick-btn">{{startYm || '起始月 ▾'}}</view>
    </picker>
    <text class="date-sep">—</text>
    <picker mode="selector" range="{{allMonths}}" bindchange="onEndPick">
      <view class="date-pick-btn">{{endYm || '结束月 ▾'}}</view>
    </picker>
    <view wx:if="{{startYm || endYm}}" class="date-clear" bindtap="onClearFilter">× 清除</view>
  </view>

  <view wx:for="{{categories}}" wx:key="line" class="card">
    <!-- 类 -->
    <view class="cat-head" data-line="{{item.line}}" bindtap="onCatTap">
      <view class="cat-left">
        <view class="cat-name">{{item.line}}<text class="cat-arrow">{{item.expanded ? ' ▲' : ' ▼'}}</text></view>
        <view class="cat-meta">{{item.peopleCount}} 人</view>
      </view>
      <view class="cat-right">
        <view class="cat-sales">{{item.salesText}}</view>
        <view class="cat-sub {{item.loss ? 'text-pink' : 'text-green'}}">毛利 {{item.profitText}} · {{item.marginPct}}%</view>
      </view>
    </view>
    <view class="cat-bar"><view class="cat-bar-fill" style="width:{{item.barWidth}}%"></view></view>

    <!-- 类下人员 -->
    <view wx:if="{{item.expanded}}" class="people">
      <view wx:for="{{item.people}}" wx:for-item="pe" wx:key="name" class="person">
        <view class="person-head" data-name="{{pe.name}}" bindtap="onPersonTap">
          <view class="person-left">
            <view class="person-name">{{pe.name}}<text class="person-arrow">{{pe.expanded ? ' ▲' : ' ▼'}}</text></view>
            <view class="person-badges">
              <text class="badge badge-own">主责 {{pe.ownCount}}</text>
              <text wx:if="{{pe.joinCount}}" class="badge badge-join">参与 {{pe.joinCount}}</text>
            </view>
          </view>
        </view>

        <!-- 个人:产品清单 + 利润汇总 + 月度利润时间轴 -->
        <view wx:if="{{pe.expanded}}" class="person-detail">
          <!-- 主责产品利润汇总 -->
          <view wx:if="{{pe.hasProfit}}" class="pe-pb-row">
            <text class="pe-pb-label">主责毛利</text>
            <text class="{{pe.personLoss ? 'text-pink' : 'text-green'}}">{{pe.personProfitText}}</text>
          </view>
          <!-- 产品列表（可展开月度利润时间轴） -->
          <view wx:for="{{pe.products}}" wx:for-item="p" wx:key="name" class="prod-item">
            <view class="prod-row" data-key="{{p.key}}" bindtap="onProductTap">
              <text class="prod-name">{{p.name}}</text>
              <view class="prod-row-right">
                <view class="prod-metrics">
                  <text class="prod-sales">{{p.salesText}}</text>
                  <text class="prod-profit {{p.loss ? 'text-pink' : 'text-green'}}"> · {{p.profitText}}</text>
                </view>
                <text class="prod-role {{p.isOwner ? 'role-own' : 'role-join'}}">{{p.role}}</text>
                <text wx:if="{{p.hasProfitTimeline}}" class="prod-expand-arrow">{{p.expanded ? '▲' : '▼'}}</text>
              </view>
            </view>
            <!-- 产品展开：月度利润时间轴(uCharts) -->
            <view wx:if="{{p.expanded && p.hasProfitTimeline}}" class="prod-lifecycle">
              <view class="lc-chart-title">月度利润时间轴 <text class="lc-legend">单位 $千 · <text class="lc-dot-pos"></text>盈利 <text class="lc-dot-neg"></text>亏损</text></view>
              <view wx:if="{{!p.chartOpts}}" class="lc-no-data">该时间段内暂无数据</view>
              <ucharts wx:else cid="pbchart" height="{{380}}" opts="{{p.chartOpts}}"></ucharts>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
  </block>

  <view class="foot-note">毛利=真实毛利（合同成本修正，逐月扣回每件成本差，与财务/类/产品页一致）· 无筛选=全期 · 数据快照 {{generatedAt}}</view>
</view>
