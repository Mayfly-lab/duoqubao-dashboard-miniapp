<view class="container">

  <view class="demo-banner">团队 = 各产品类下的 <text class="text-green">负责人 / 参与人</text>（registry 归属）· 个人毛利只计主责 · 费用动作 opex 全期（型号级偏漏）。</view>

  <view wx:if="{{loading}}" class="card">加载中…</view>
  <view wx:if="{{error}}" class="card" style="color:#f06292">{{error}}</view>

  <block wx:if="{{!loading && !error}}">
  <view class="role-hint">按产品类看人员 · 数据快照 {{generatedAt}} · 全期累计</view>

  <view wx:for="{{categories}}" wx:key="line" class="card">
    <!-- 类 -->
    <view class="cat-head" data-line="{{item.line}}" bindtap="onCatTap">
      <view class="cat-left">
        <view class="cat-name">{{item.line}}<text class="cat-arrow">{{item.expanded ? ' ▲' : ' ▼'}}</text></view>
        <view class="cat-meta">{{item.peopleCount}} 人</view>
      </view>
      <view class="cat-right">
        <view class="cat-sales">{{item.salesText}}</view>
        <view class="cat-sub {{item.loss ? 'text-pink' : 'text-green'}}">毛利 {{item.profitText}} · {{item.marginPct}}%</view>
      </view>
    </view>
    <view class="cat-bar"><view class="cat-bar-fill" style="width:{{item.barWidth}}%"></view></view>

    <!-- 类下人员 -->
    <view wx:if="{{item.expanded}}" class="people">
      <view wx:for="{{item.people}}" wx:for-item="pe" wx:key="name" class="person">
        <view class="person-head" data-name="{{pe.name}}" bindtap="onPersonTap">
          <view class="person-name">{{pe.name}}<text class="person-arrow">{{pe.expanded ? ' ▲' : ' ▼'}}</text></view>
          <view class="person-right">
            <view class="person-contrib {{pe.loss ? 'text-pink' : 'text-green'}}">毛利 {{pe.profitText}}</view>
            <view class="person-opex">费用动作 {{pe.opexTotalText}}</view>
          </view>
        </view>

        <!-- 个人:负责产品 + 费用动作 -->
        <view wx:if="{{pe.expanded}}" class="person-detail">
          <view wx:for="{{pe.products}}" wx:for-item="p" wx:key="name" class="prod-block">
            <view class="prod-row">
              <text class="prod-name">{{p.name}}<text class="prod-role">{{p.role}}</text></text>
              <text class="prod-val {{p.loss ? 'text-pink' : 'text-green'}}">{{p.salesText}}</text>
            </view>
            <view wx:if="{{p.actions.length}}" class="prod-acts">
              <view wx:for="{{p.actions}}" wx:for-item="a" wx:key="category" class="act-row">
                <text class="act-name">· {{a.category}}</text>
                <text class="act-val">{{a.costText}}</text>
              </view>
            </view>
            <view wx:else class="empty-mini">· 无报销记录（型号级偏漏）</view>
          </view>
        </view>
      </view>
    </view>
  </view>
  </block>

  <view class="foot-note">数据：领星 + 金蝶财务（duoqubao-api 快照 {{generatedAt}}）· 团队按产品类组织 · 个人毛利只计主责</view>
</view>
