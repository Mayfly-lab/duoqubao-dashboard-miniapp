/* 角色切换（与财务看板一致） */
.role-bar { display: flex; background: #19233c; border: 1rpx solid #2c3a5c; border-radius: 16rpx; padding: 6rpx; margin-bottom: 12rpx; }
.role-tab { flex: 1; text-align: center; padding: 14rpx 0; font-size: 26rpx; color: #94a3c4; border-radius: 12rpx; }
.role-tab-on { background: #5b8cff; color: #fff; font-weight: 600; }
.role-hint { font-size: 22rpx; color: #6b7280; margin-bottom: 24rpx; }

/* 员工卡 */
.emp { padding: 24rpx 0; border-bottom: 1rpx solid #2c3a5c; }
.emp:last-child { border-bottom: none; }
.emp-head { display: flex; justify-content: space-between; align-items: flex-start; }
.emp-name { font-size: 30rpx; font-weight: 600; color: #eef2fb; }
.emp-team { font-size: 20rpx; color: #94a3c4; border: 1rpx solid #2c3a5c; border-radius: 8rpx; padding: 2rpx 10rpx; margin-left: 12rpx; }
.emp-meta { font-size: 22rpx; color: #6b7280; margin-top: 6rpx; }
.emp-right { text-align: right; }
.emp-contrib { font-size: 32rpx; font-weight: 700; }
.emp-sub { font-size: 20rpx; color: #94a3c4; margin-top: 4rpx; }
.emp-loss .emp-name { color: #f06292; }

.emp-bar { height: 8rpx; background: #0f1729; border-radius: 4rpx; margin-top: 16rpx; overflow: hidden; }
.emp-bar-fill { height: 100%; background: #22c4a8; border-radius: 4rpx; }
.emp-loss .emp-bar-fill { background: #f06292; }

.emp-stats { display: flex; margin-top: 18rpx; }
.stat { flex: 1; text-align: center; }
.stat-num { display: block; font-size: 28rpx; font-weight: 600; color: #eef2fb; }
.stat-lab { display: block; font-size: 20rpx; color: #94a3c4; margin-top: 4rpx; }

.foot-note { text-align: center; font-size: 20rpx; color: #6b7280; margin-top: 32rpx; }
