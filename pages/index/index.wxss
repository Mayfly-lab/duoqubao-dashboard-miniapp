/* 核心结论卡 */
.conclusion-card {
  background: linear-gradient(140deg, #eaf1ff, #effaf4);
  border: 1rpx solid #cfe9df;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 32rpx;
}
.conclusion-label {
  font-size: 22rpx;
  color: #18b888;
  font-weight: 600;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
}
.conclusion-main {
  font-size: 30rpx;
  color: #1f2a3c;
  line-height: 1.8;
  margin-bottom: 24rpx;
}
.conclusion-main .hl {
  font-size: 38rpx;
  font-weight: 700;
  color: #18b888;
}
.conclusion-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.pill {
  font-size: 22rpx;
  color: #6b7891;
  background: #edf0f5;
  border: 1rpx solid #edf0f5;
  border-radius: 999rpx;
  padding: 6rpx 20rpx;
}
.conclusion-formula {
  font-size: 20rpx;
  color: #9aa6bc;
  margin-top: 20rpx;
  line-height: 1.6;
  border-top: 1rpx solid #edf0f5;
  padding-top: 16rpx;
}
.pill-green {
  color: #18b888;
  background: rgba(34,196,168,.08);
  border-color: rgba(34,196,168,.3);
}

.section-label {
  font-size: 22rpx;
  color: #9aa6bc;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
}

/* KPI grid */
.kpi-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.kpi-card {
  background: #f3f6fc;
  border: 1rpx solid #edf0f5;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
}
.kpi-val {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.1;
}
.kpi-label {
  font-size: 22rpx;
  color: #6b7891;
  margin-top: 8rpx;
}
.kpi-sub {
  font-size: 20rpx;
  color: #9aa6bc;
  margin-top: 6rpx;
  line-height: 1.4;
}
.kpi-blue   .kpi-val { color: #2b6cff; }
.kpi-green  .kpi-val { color: #18b888; }
.kpi-yellow .kpi-val { color: #f0a020; }
.kpi-purple .kpi-val { color: #7c5cff; }
.kpi-pink   .kpi-val { color: #f5455c; }
.kpi-indigo .kpi-val { color: #7c9cff; }

/* 趋势图 */
.trend-wrap {
  display: flex;
  align-items: flex-end;
  height: 220rpx;
  gap: 8rpx;
}
.tcol {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
  justify-content: flex-end;
  gap: 6rpx;
}
.tval { font-size: 18rpx; color: #6b7891; }
.tbar-wrap {
  width: 100%;
  flex: 1;
  display: flex;
  align-items: flex-end;
}
.tbar {
  width: 70%;
  margin: 0 auto;
  background: linear-gradient(180deg, #2b6cff, #3a5bb0);
  border-radius: 6rpx 6rpx 0 0;
  min-height: 4rpx;
}
.tcol.today .tbar { background: linear-gradient(180deg, #f0a020, #b97a16); }
.tdate { font-size: 18rpx; color: #9aa6bc; white-space: nowrap; }

/* 环形图 */
.ring-wrap { display: flex; justify-content: center; margin: 16rpx 0; }
.ring-canvas { width: 320rpx; height: 320rpx; }

/* 图例 */
.legend-wrap { margin-top: 24rpx; }
.legend-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #1e2d4a;
}
.legend-item:last-child { border-bottom: none; }
.legend-dot { width: 20rpx; height: 20rpx; border-radius: 50%; flex-shrink: 0; }
.legend-name { flex: 1; font-size: 26rpx; color: #1f2a3c; }
.legend-pct { font-size: 26rpx; color: #6b7891; width: 72rpx; text-align: right; }
.legend-n { font-size: 26rpx; color: #9aa6bc; width: 72rpx; text-align: right; }

/* 排行入口 */
.rank-entry { display: flex; align-items: center; justify-content: space-between; }
.rank-entry-arrow { font-size: 56rpx; color: #6b7891; line-height: 1; }

/* 底部数据说明 */
.data-note {
  font-size: 22rpx;
  color: #9aa6bc;
  text-align: center;
  margin-top: 8rpx;
  padding-bottom: 20rpx;
}
