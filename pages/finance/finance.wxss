/* 角色切换 */
.role-bar {
  display: flex;
  background: #19233c;
  border: 1rpx solid #2c3a5c;
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 12rpx;
}
.role-tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 26rpx;
  color: #94a3c4;
  border-radius: 12rpx;
}
.role-tab-on {
  background: #5b8cff;
  color: #fff;
  font-weight: 600;
}
.role-hint {
  font-size: 22rpx;
  color: #6b7280;
  margin-bottom: 24rpx;
}

/* 异常预警卡 */
.alert-card {
  background: #19233c;
  border: 1rpx solid #3a2c3c;
  border-radius: 20rpx;
  padding: 24rpx 24rpx 12rpx;
  margin-bottom: 24rpx;
}
.alert-title { font-size: 26rpx; font-weight: 600; color: #f5a524; margin-bottom: 16rpx; }
.alert-row {
  display: flex; align-items: center;
  padding: 14rpx 0; border-top: 1rpx solid #2c3a5c;
}
.alert-tag {
  font-size: 20rpx; padding: 4rpx 14rpx; border-radius: 999rpx; margin-right: 16rpx;
  flex-shrink: 0;
}
.alert-tag-high { background: rgba(240,98,146,.18); color: #f06292; }
.alert-tag-mid  { background: rgba(245,165,36,.18); color: #f5a524; }
.alert-body { flex: 1; min-width: 0; }
.alert-name { font-size: 26rpx; color: #eef2fb; margin-right: 12rpx; }
.alert-msg  { font-size: 22rpx; color: #94a3c4; }
.alert-arrow { font-size: 32rpx; color: #6b7280; margin-left: 12rpx; }

/* KPI 网格 */
.kpi-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.kpi-item {
  width: 48%;
  margin-bottom: 16rpx;
  background: #19233c;
  border: 1rpx solid #2c3a5c;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-sizing: border-box;
}
.kpi-num { font-size: 42rpx; font-weight: 700; }
.kpi-label { font-size: 22rpx; color: #94a3c4; margin-top: 8rpx; }

/* 项目行 */
.proj {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #2c3a5c;
}
.proj:last-child { border-bottom: none; }
.proj-head { display: flex; justify-content: space-between; align-items: flex-start; }
.proj-name { font-size: 30rpx; font-weight: 600; color: #eef2fb; }
.proj-team {
  font-size: 20rpx; color: #94a3c4;
  border: 1rpx solid #2c3a5c; border-radius: 8rpx;
  padding: 2rpx 10rpx; margin-left: 12rpx;
}
.proj-meta { font-size: 22rpx; color: #6b7280; margin-top: 6rpx; }
.proj-right { text-align: right; }
.proj-sales { font-size: 30rpx; font-weight: 600; color: #eef2fb; }
.proj-sub { font-size: 22rpx; margin-top: 6rpx; }
.proj-loss .proj-name { color: #f06292; }

/* 销售额条 */
.proj-bar {
  height: 8rpx; background: #0f1729; border-radius: 4rpx;
  margin-top: 16rpx; overflow: hidden;
}
.proj-bar-fill { height: 100%; background: #5b8cff; border-radius: 4rpx; }
.proj-loss .proj-bar-fill { background: #f06292; }

/* 费用拆解 */
.costs {
  margin-top: 20rpx; padding: 20rpx;
  background: #0f1729; border-radius: 16rpx;
}
.costs-title { font-size: 24rpx; color: #94a3c4; margin-bottom: 16rpx; }
.cost-row { display: flex; align-items: center; margin-bottom: 14rpx; }
.cost-name { width: 280rpx; font-size: 22rpx; color: #cbd5e1; }
.cost-bar {
  flex: 1; height: 12rpx; background: #19233c;
  border-radius: 6rpx; margin: 0 16rpx; overflow: hidden;
}
.cost-bar-fill { height: 100%; background: #f5a524; border-radius: 6rpx; }
.cost-val { width: 130rpx; text-align: right; font-size: 22rpx; color: #f5a524; }
.cost-empty { font-size: 22rpx; color: #6b7280; }
.detail-link { text-align: right; font-size: 24rpx; color: #5b8cff; margin-top: 16rpx; }

.foot-note {
  text-align: center; font-size: 20rpx; color: #6b7280; margin-top: 32rpx;
}

/* ── 产品类对比 / 筛选 / 折叠(P1) ── */
.card-head {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 8rpx;
}
.card-head .card-title { margin-bottom: 0; }
.empty-hint { font-size: 22rpx; color: #6b7280; padding: 24rpx 0; text-align: center; }
.collapse-toggle {
  text-align: center; font-size: 24rpx; color: #5b8cff;
  padding: 20rpx 0 4rpx; border-top: 1rpx solid #2c3a5c; margin-top: 8rpx;
}

/* 产品类行(参考 proj) */
.cat { padding: 24rpx 0; border-bottom: 1rpx solid #2c3a5c; }
.cat:last-child { border-bottom: none; }
.cat-head { display: flex; justify-content: space-between; align-items: center; padding: 10rpx 16rpx; margin: 0 -16rpx; border-radius: 10rpx; }
.cat-head:active { background: rgba(91,140,255,.12); }
.go-arrow { font-size: 34rpx; color: #5b8cff; margin-left: 16rpx; flex-shrink: 0; line-height: 1; }
.cat-name { font-size: 30rpx; font-weight: 600; color: #eef2fb; }
.cat-meta { font-size: 22rpx; color: #6b7280; margin-top: 6rpx; }
.cat-right { text-align: right; }
.cat-sales { font-size: 30rpx; font-weight: 600; color: #eef2fb; }
.cat-sub { font-size: 22rpx; margin-top: 6rpx; }
.cat-loss .cat-name { color: #f06292; }
.cat-bar { height: 8rpx; background: #0f1729; border-radius: 4rpx; margin-top: 16rpx; overflow: hidden; }
.cat-bar-fill { height: 100%; background: #5b8cff; border-radius: 4rpx; }
.cat-loss .cat-bar-fill { background: #f06292; }

/* 类展开:整体指标 */
.cat-detail { margin-top: 20rpx; padding: 24rpx 20rpx; background: #0f1729; border-radius: 16rpx; }
.cat-metrics { display: flex; flex-wrap: wrap; justify-content: space-between; }
.metric {
  width: 48%; margin-bottom: 16rpx; box-sizing: border-box;
  background: #19233c; border: 1rpx solid #2c3a5c; border-radius: 14rpx; padding: 20rpx;
}
.metric-num { font-size: 30rpx; font-weight: 700; white-space: nowrap; }
.metric-label { font-size: 20rpx; color: #94a3c4; margin-top: 6rpx; }
.enter-btn {
  text-align: center; font-size: 26rpx; color: #fff; font-weight: 600;
  background: #5b8cff; border-radius: 14rpx; padding: 20rpx 0; margin-top: 20rpx;
}

/* 净利单行(币种与上方 KPI 不同,独立展示) */
.net-line { margin-top: 16rpx; padding: 16rpx 20rpx; background: rgba(255,255,255,.03); border-radius: 12rpx; display: flex; flex-wrap: wrap; align-items: baseline; gap: 8rpx 14rpx; }
.net-key { font-size: 26rpx; color: #9aa4b2; }
.net-val { font-size: 38rpx; font-weight: 700; }
.net-note { width: 100%; font-size: 20rpx; color: #6b7280; line-height: 1.5; }
