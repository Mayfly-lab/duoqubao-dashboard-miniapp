/* 角色切换 */
.role-bar {
  display: flex;
  background: #eef1f6;
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 12rpx;
}
.role-tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 26rpx;
  color: var(--t2);
  border-radius: 12rpx;
}
.role-tab-on {
  background: var(--primary);
  color: #fff;
  font-weight: 600;
}
.role-hint {
  font-size: 22rpx;
  color: var(--t3);
  margin-bottom: 24rpx;
}

/* 异常预警卡 */
.alert-card {
  background: var(--card);
  border-radius: 20rpx;
  padding: 24rpx 24rpx 12rpx;
  margin-bottom: 22rpx;
  box-shadow: 0 2rpx 16rpx rgba(31,42,60,.06);
}
.alert-title { font-size: 26rpx; font-weight: 600; color: #f0a020; margin-bottom: 16rpx; }
.alert-row {
  display: flex; align-items: center;
  padding: 14rpx 0; border-top: 1rpx solid var(--line);
}
.alert-tag {
  font-size: 20rpx; padding: 4rpx 14rpx; border-radius: 999rpx; margin-right: 16rpx;
  flex-shrink: 0;
}
.alert-tag-high { background: rgba(245,69,92,.12); color: var(--up); }
.alert-tag-mid  { background: rgba(240,160,32,.14); color: #f0a020; }
.alert-body { flex: 1; min-width: 0; }
.alert-name { font-size: 26rpx; color: var(--t1); margin-right: 12rpx; }
.alert-msg  { font-size: 22rpx; color: var(--t2); }
.alert-arrow { font-size: 32rpx; color: var(--t3); margin-left: 12rpx; }

/* KPI 网格(领星浅蓝内框) */
.kpi-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.kpi-item {
  width: 48%;
  margin-bottom: 16rpx;
  background: var(--tint);
  border-radius: 16rpx;
  padding: 26rpx 24rpx;
  box-sizing: border-box;
}
.kpi-num { font-size: 42rpx; font-weight: 700; color: var(--primary); }
.kpi-label { font-size: 22rpx; color: var(--t2); margin-top: 8rpx; }

/* 项目行 */
.proj {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--line);
}
.proj:last-child { border-bottom: none; }
.proj-head { display: flex; justify-content: space-between; align-items: flex-start; }
.proj-name { font-size: 30rpx; font-weight: 600; color: var(--t1); }
.proj-team {
  font-size: 20rpx; color: var(--t2);
  border: 1rpx solid var(--line); border-radius: 8rpx;
  padding: 2rpx 10rpx; margin-left: 12rpx;
}
.proj-meta { font-size: 22rpx; color: var(--t3); margin-top: 6rpx; }
.proj-right { text-align: right; }
.proj-sales { font-size: 30rpx; font-weight: 600; color: var(--t1); }
.proj-sub { font-size: 22rpx; margin-top: 6rpx; }
.proj-loss .proj-name { color: var(--up); }

/* 销售额条 */
.proj-bar {
  height: 8rpx; background: #eef1f6; border-radius: 4rpx;
  margin-top: 16rpx; overflow: hidden;
}
.proj-bar-fill { height: 100%; background: var(--primary); border-radius: 4rpx; }
.proj-loss .proj-bar-fill { background: var(--up); }

/* 费用拆解 */
.costs {
  margin-top: 20rpx; padding: 20rpx;
  background: var(--tint); border-radius: 16rpx;
}
.costs-title { font-size: 24rpx; color: var(--t2); margin-bottom: 16rpx; }
.cost-row { display: flex; align-items: center; margin-bottom: 14rpx; }
.cost-name { width: 280rpx; font-size: 22rpx; color: var(--t1); }
.cost-bar {
  flex: 1; height: 12rpx; background: #e7ebf2;
  border-radius: 6rpx; margin: 0 16rpx; overflow: hidden;
}
.cost-bar-fill { height: 100%; background: #f0a020; border-radius: 6rpx; }
.cost-val { width: 130rpx; text-align: right; font-size: 22rpx; color: #f0a020; }
.cost-empty { font-size: 22rpx; color: var(--t3); }
.detail-link { text-align: right; font-size: 24rpx; color: var(--primary); margin-top: 16rpx; }

.foot-note {
  text-align: center; font-size: 20rpx; color: var(--t3); margin-top: 32rpx;
}

/* ── 产品类对比 / 筛选 / 折叠 ── */
.card-head {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 8rpx;
}
.card-head .card-title { margin-bottom: 0; }
.empty-hint { font-size: 22rpx; color: var(--t3); padding: 24rpx 0; text-align: center; }
.collapse-toggle {
  text-align: center; font-size: 24rpx; color: var(--primary);
  padding: 20rpx 0 4rpx; border-top: 1rpx solid var(--line); margin-top: 8rpx;
}

/* 产品类行 */
.cat { padding: 24rpx 0; border-bottom: 1rpx solid var(--line); }
.cat:last-child { border-bottom: none; }
.cat-head { display: flex; justify-content: space-between; align-items: center; padding: 10rpx 16rpx; margin: 0 -16rpx; border-radius: 10rpx; }
.cat-head:active { background: var(--primary-weak); }
.go-arrow { font-size: 34rpx; color: var(--primary); margin-left: 16rpx; flex-shrink: 0; line-height: 1; }
.cat-name { font-size: 30rpx; font-weight: 600; color: var(--t1); }
.cat-meta { font-size: 22rpx; color: var(--t3); margin-top: 6rpx; }
.cat-right { text-align: right; }
.cat-sales { font-size: 30rpx; font-weight: 600; color: var(--t1); }
.cat-sub { font-size: 22rpx; margin-top: 6rpx; }
.cat-loss .cat-name { color: var(--up); }
.cat-bar { height: 8rpx; background: #eef1f6; border-radius: 4rpx; margin-top: 16rpx; overflow: hidden; }
.cat-bar-fill { height: 100%; background: var(--primary); border-radius: 4rpx; }
.cat-loss .cat-bar-fill { background: var(--up); }

/* 类展开:整体指标 */
.cat-detail { margin-top: 20rpx; padding: 24rpx 20rpx; background: var(--tint); border-radius: 16rpx; }
.cat-metrics { display: flex; flex-wrap: wrap; justify-content: space-between; }
.metric {
  width: 48%; margin-bottom: 16rpx; box-sizing: border-box;
  background: var(--card); border: 1rpx solid var(--line); border-radius: 14rpx; padding: 20rpx;
}
.metric-num { font-size: 30rpx; font-weight: 700; white-space: nowrap; }
.metric-label { font-size: 20rpx; color: var(--t2); margin-top: 6rpx; }
.enter-btn {
  text-align: center; font-size: 26rpx; color: #fff; font-weight: 600;
  background: var(--primary); border-radius: 14rpx; padding: 20rpx 0; margin-top: 20rpx;
}

/* 净利单行 */
.net-line { margin-top: 16rpx; padding: 16rpx 20rpx; background: var(--tint); border-radius: 12rpx; display: flex; flex-wrap: wrap; align-items: baseline; gap: 8rpx 14rpx; }
.net-key { font-size: 26rpx; color: var(--t2); }
.net-val { font-size: 38rpx; font-weight: 700; }
.net-note { width: 100%; font-size: 20rpx; color: var(--t3); line-height: 1.5; }

/* 公司资金预览(钱和货优先) */
.fund-grid { display: flex; flex-wrap: wrap; justify-content: space-between; }
.fund-item {
  width: 48%; box-sizing: border-box; margin-bottom: 16rpx;
  background: var(--tint); border-radius: 16rpx; padding: 26rpx 24rpx;
}
.fund-num { font-size: 40rpx; font-weight: 700; color: var(--t1); white-space: nowrap; }
.fund-label { font-size: 22rpx; color: var(--t2); margin-top: 8rpx; }
/* 账上现金:主色强调大卡 */
.fund-cash { background: var(--primary); }
.fund-cash .fund-num { color: #fff; }
.fund-cash .fund-label { color: rgba(255,255,255,.85); }

/* 销售盈亏 折叠卡 */
.sales-card .card-head { margin-bottom: 0; }
.collapse-arrow { font-size: 24rpx; color: var(--t3); }

/* 每产品双进度条(能拿回 vs 要付·经营驾驶舱风格) */
.fb-legend { font-size: 20rpx; color: var(--t2); margin-bottom: 14rpx; }
.fb-dot { display:inline-block; width:16rpx; height:16rpx; border-radius:4rpx; vertical-align:middle; margin: 0 6rpx 0 14rpx; }
.fb-dot-got { background: var(--primary); }
.fb-dot-pend { background: repeating-linear-gradient(45deg, #6ba3ff, #6ba3ff 4rpx, transparent 4rpx, transparent 8rpx); border:1rpx solid #6ba3ff; }
.fb-dot-owe { background: #f0a020; }
.fb-prod { margin-bottom: 18rpx; }
.fb-name { font-size: 24rpx; color: var(--t1); margin-bottom: 6rpx; }
.fb-row { display: flex; align-items: center; margin-bottom: 5rpx; }
.fb-track { flex: 1; display: flex; height: 18rpx; background: #eef1f6; border-radius: 5rpx; overflow: hidden; }
.fb-seg { height: 100%; }
.fb-got { background: var(--primary); }
.fb-pend { background: repeating-linear-gradient(45deg, #6ba3ff, #6ba3ff 5rpx, rgba(107,163,255,.25) 5rpx, rgba(107,163,255,.25) 10rpx); }
.fb-owe { background: #f0a020; border-radius: 0 5rpx 5rpx 0; }
.fb-val { width: 150rpx; text-align: right; font-size: 22rpx; color: var(--t2); flex-shrink: 0; }

/* 经营费用 opex 条 + 占位 */
.opex-fill { background: #f0a020; }
.opex-placeholder { margin-top: 16rpx; padding-top: 14rpx; border-top: 1rpx solid var(--line); }
.opex-placeholder .ph-row { display: block; font-size: 22rpx; color: var(--t2); padding: 6rpx 0; }

/* 真实毛利标签 */
.net-tag { font-size: 24rpx; font-weight: 600; color: var(--t2); }

/* 毛利"真实"小标 */
.real-flag { display:inline-block; margin-left:6rpx; padding:0 8rpx; font-size:18rpx; color:#18b888; background:rgba(24,184,136,.12); border-radius:5rpx; vertical-align:middle; }

/* ═══ 资金卡(能拿回 vs 应付线 → 可动用) ═══ */
.board-eyebrow { font-size: 19rpx; color: var(--t3); }
.fc-headline { font: 700 52rpx 'DIN Alternate','Space Grotesk',sans-serif; margin: 2rpx 0 6rpx; }
.fc-hl-lab { font-size: 22rpx; font-weight: 500; color: var(--t3); margin-left: 10rpx; }
.fc-lab { font-size: 21rpx; color: var(--t2); margin-top: 16rpx; }
.fc-b { font-weight: 700; color: var(--t1); font-size: 26rpx; margin-left: 4rpx; }
.fc-lab2 { font-size: 18rpx; color: var(--t3); margin: 6rpx 0 2rpx; }
/* 条 */
.fc-bar { position: relative; height: 48rpx; display: flex; background: var(--tint); border-radius: 10rpx; margin: 8rpx 0; }
.fc-seg { height: 48rpx; display: flex; align-items: center; justify-content: center; overflow: hidden; }
.fc-seg:first-child { border-radius: 10rpx 0 0 10rpx; }
.fc-seg-t { font-size: 18rpx; color: #fff; white-space: nowrap; padding: 0 6rpx; }
.fc-cash { background: #2b6cff; }
.fc-pend { background: #9dbcff; }
.fc-owe { background: #f5455c; border-radius: 10rpx; }
.fc-bar-owe { background: var(--tint); }
/* 应付线(竖虚线) */
.fc-oweline { position: absolute; top: -8rpx; bottom: -8rpx; width: 0; border-left: 3rpx dashed #1f2a3c; z-index: 2; }
.fc-oweline-t { position: absolute; top: -26rpx; left: 6rpx; font-size: 15rpx; color: #1f2a3c; white-space: nowrap; }
/* 健康提示 */
.fc-health { font-size: 20rpx; padding: 12rpx 14rpx; border-radius: 8rpx; margin-top: 14rpx; }
.fc-ok { background: rgba(24,184,136,.1); color: #18b888; }
.fc-warn { background: rgba(245,69,92,.1); color: #f5455c; }
/* 下钻明细 */
.fc-detail { margin-top: 16rpx; padding-top: 12rpx; border-top: 1rpx solid var(--line); }
.fc-dtitle { font-size: 22rpx; color: var(--t2); font-weight: 600; margin-bottom: 10rpx; display: flex; justify-content: space-between; }
.fc-dclose { color: var(--t3); font-weight: normal; }
.fc-drow { display: flex; align-items: center; gap: 10rpx; padding: 7rpx 0; }
.fc-dname { font-size: 20rpx; color: var(--t1); flex: 0 0 190rpx; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.fc-dtag { font-size: 16rpx; color: var(--t3); }
.fc-dexp { font-size: 16rpx; color: var(--t3); }
.fc-dbar { flex: 1; height: 12rpx; background: var(--tint); border-radius: 6rpx; overflow: hidden; }
.fc-dbar-f { height: 100%; border-radius: 6rpx; }
.fc-df-cash { background: #2b6cff; }
.fc-df-owe { background: #f5455c; }
.fc-dval { font-size: 20rpx; color: var(--t1); flex: 0 0 auto; min-width: 120rpx; text-align: right; }
.fc-contracts { padding: 6rpx 0 8rpx 16rpx; background: var(--tint); border-radius: 8rpx; margin: 4rpx 0 8rpx; }
.fc-crow { display: flex; justify-content: space-between; gap: 8rpx; padding: 5rpx 10rpx; font-size: 18rpx; }
.fc-cnm { color: var(--t1); flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.fc-camt { color: var(--t3); flex: 0 0 auto; }
.fc-cowe { flex: 0 0 auto; }
.fc-dnote { font-size: 19rpx; color: var(--t2); line-height: 1.5; }

/* ═══ 库存卡·库龄横条 ═══ */
.age-title { font-size: 21rpx; color: var(--t2); margin-top: 16rpx; }
.age-sub { font-size: 17rpx; color: var(--t3); margin-left: 6rpx; }
.age-bar { display: flex; height: 22rpx; border-radius: 6rpx; overflow: hidden; margin: 10rpx 0; background: var(--tint); }
.age-seg { height: 100%; }
.age-h { background: #18b888; }
.age-1 { background: #f0c020; }
.age-2 { background: #f0a020; }
.age-3 { background: #f5704a; }
.age-4 { background: #f5455c; }
.age-legend { display: flex; flex-wrap: wrap; gap: 6rpx 16rpx; }
.age-lg { font-size: 17rpx; color: var(--t2); display: flex; align-items: center; }
.age-dot { display: inline-block; width: 14rpx; height: 14rpx; border-radius: 3rpx; margin-right: 5rpx; }
/* ═══ 销售卡·按部门 ═══ */
.byb-title { font-size: 21rpx; color: var(--t2); margin: 16rpx 0 8rpx; font-weight: 600; }
.byb-row { display: flex; align-items: center; padding: 8rpx 0; border-top: 1rpx solid var(--line); }
.byb-name { font-size: 22rpx; color: var(--t1); font-weight: 600; flex: 0 0 90rpx; }
.byb-sales { font-size: 22rpx; color: var(--t1); flex: 1; }
.byb-margin { font-size: 20rpx; flex: 0 0 auto; }

/* ═══ 滞销超龄·每档一行横条(越久越深,覆盖上面 age-1~4) ═══ */
.age-total { font-size: 20rpx; color: #f5455c; font-weight: 700; margin-left: 6rpx; }
.age-sub2 { font-size: 17rpx; color: var(--t3); margin: 4rpx 0 10rpx; }
.ab-row { display: flex; align-items: center; gap: 10rpx; padding: 5rpx 0; }
.ab-lab { font-size: 19rpx; color: var(--t2); flex: 0 0 140rpx; }
.ab-track { flex: 1; height: 16rpx; background: var(--tint); border-radius: 4rpx; overflow: hidden; }
.ab-fill { height: 100%; border-radius: 4rpx; }
.ab-val { font-size: 19rpx; color: var(--t1); flex: 0 0 auto; min-width: 90rpx; text-align: right; }
.ab-warn .ab-lab, .ab-warn .ab-val { color: #8A3A1E; font-weight: 700; }
.age-healthy { font-size: 18rpx; color: var(--t2); margin-top: 10rpx; }
.age-1 { background: #E8B89E; }
.age-2 { background: #D98E66; }
.age-3 { background: #C66A43; }
.age-4 { background: #8A3A1E; }

/* 类对比展开·回本双条(已支付段 + 盈利) */
.fb-dot-paid { background: #f0a020; }
.fb-paid { background: #f0a020; }
.fb-back { font-size: 21rpx; font-weight: 700; margin-left: 10rpx; }

/* ═══ 资金卡下钻明细·放大易点(覆盖上面小号) ═══ */
.fc-dtitle { font-size: 26rpx; margin-bottom: 14rpx; }
.fc-dhint { font-size: 20rpx; color: var(--primary); margin: 4rpx 0 10rpx; }
.fc-drow { gap: 12rpx; padding: 16rpx 0; min-height: 56rpx; }
.fc-drow-tap { padding: 16rpx 12rpx; margin: 4rpx 0; background: var(--tint); border-radius: 10rpx; }
.fc-dname { font-size: 25rpx; flex: 0 0 210rpx; }
.fc-dval { font-size: 25rpx; min-width: 130rpx; }
.fc-dchev { font-size: 21rpx; color: var(--primary); flex: 0 0 auto; margin-left: 8rpx; }
.fc-contracts { padding: 8rpx 0 12rpx 20rpx; }
.fc-crow { padding: 10rpx 12rpx; font-size: 22rpx; }

/* 类对比 header 回本口径小字 */
.cat-sub2 { font-size: 17rpx; color: var(--t3); margin-left: 8rpx; }
