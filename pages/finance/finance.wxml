<view class="container">

  <view wx:if="{{loading}}" class="role-hint">加载中…</view>
  <view wx:if="{{error}}" class="role-hint" style="color:#f5455c">{{error}}</view>

  <!-- 待关注（AI 监控）· 老板第一眼 -->
  <view class="card">
    <view class="card-head">
      <view class="card-title">⚠️ 待关注 · {{alertTotal}} 项</view>
      <filter-dropdown options="{{alertFilters}}" value="{{alertFilter}}" bind:change="onAlertFilterChange" />
    </view>
    <view wx:if="{{alertTotal === 0}}" class="empty-hint">当前筛选下无待关注项</view>
    <view wx:for="{{alerts}}" wx:key="index" class="alert-row alert-{{item.level}}" data-name="{{item.name}}" bindtap="onAlertTap">
      <view class="alert-tag alert-tag-{{item.level}}">{{item.tag}}</view>
      <view class="alert-body">
        <text class="alert-name">{{item.name}}</text>
        <text class="alert-msg">{{item.msg}}</text>
      </view>
      <view class="alert-arrow">›</view>
    </view>
    <view wx:if="{{alertTotal > 3}}" class="collapse-toggle" bindtap="onToggleAlerts">
      {{showAllAlerts ? '收起 ▲' : '展开全部 ' + alertTotal + ' 项 ▼'}}
    </view>
  </view>

  <!-- 公司资金预览(钱和货优先) -->
  <view class="card">
    <view class="card-title">💰 公司资金预览</view>
    <view class="card-hint">电商先看钱和货 · 多趣+格致合计 · 数据快照 {{generatedAt}}</view>
    <view class="fund-grid">
      <view class="fund-item fund-cash">
        <view class="fund-num">{{fund.cash}}</view>
        <view class="fund-label">账上现金</view>
      </view>
      <view class="fund-item">
        <view class="fund-num text-yellow">{{fund.pending}}</view>
        <view class="fund-label">卡着没回（待回款）</view>
      </view>
      <view class="fund-item">
        <view class="fund-num text-pink">{{fund.owe}}</view>
        <view class="fund-label">还要付（欠厂）</view>
      </view>
      <view class="fund-item">
        <view class="fund-num text-blue">{{fund.goods}}</view>
        <view class="fund-label">货值 · {{fund.stockQty}} 件（在库+在途）</view>
      </view>
    </view>
  </view>

  <!-- 库存模块 -->
  <view class="card">
    <view class="card-title">📦 库存</view>
    <view class="card-hint">现货可马上卖 · 在途已发未到 · 滞销=库龄超 365 天(占用现金)</view>
    <view class="fund-grid">
      <view class="fund-item"><view class="fund-num text-blue">{{inv.xianhuo}}</view><view class="fund-label">现货可售(件)</view></view>
      <view class="fund-item"><view class="fund-num text-yellow">{{inv.zaitu}}</view><view class="fund-label">在途(件)</view></view>
      <view class="fund-item"><view class="fund-num">{{inv.stockValue}}</view><view class="fund-label">在库货值</view></view>
      <view class="fund-item"><view class="fund-num text-pink">{{inv.agedQty365}}</view><view class="fund-label">滞销 ·超365天(件)/{{inv.agedMsku365}}款</view></view>
    </view>
  </view>

  <!-- 经营费用模块 -->
  <view class="card">
    <view class="card-title">💸 经营费用</view>
    <view class="card-hint">运营费用=金蝶真账(按对方科目) · 报销待员工填报补全 · 合计 {{opexMod.total}}</view>
    <view wx:for="{{opexMod.items}}" wx:key="category" class="cost-row">
      <view class="cost-name">{{item.category}}</view>
      <view class="cost-bar"><view class="cost-bar-fill opex-fill" style="width:{{item.barWidth}}%"></view></view>
      <view class="cost-val">{{item.costText}}</view>
    </view>
    <view class="opex-placeholder">
      <text class="ph-row">📋 员工报销 · <text class="text-dim">待填报补全</text></text>
      <text class="ph-row">🏷️ 滞销长期仓储费 · <text class="text-dim">待接入</text></text>
    </view>
  </view>

  <!-- 销售盈亏(次要,折叠) -->
  <view class="card sales-card" bindtap="onTogglePnl">
    <view class="card-head">
      <view class="card-title">📊 销售盈亏（次要）</view>
      <text class="collapse-arrow">{{pnlExpanded ? '▲' : '▼'}}</text>
    </view>
    <view wx:if="{{pnlExpanded}}">
      <view class="kpi-grid">
        <view class="kpi-item"><view class="kpi-num text-blue">{{kpi.sales}}</view><view class="kpi-label">销售额</view></view>
        <view class="kpi-item"><view class="kpi-num {{kpi.profit[0] === '-' ? 'text-pink' : 'text-green'}}">{{kpi.profit}}</view><view class="kpi-label">毛利</view></view>
        <view class="kpi-item"><view class="kpi-num text-yellow">{{kpi.marginPct}}%</view><view class="kpi-label">毛利率</view></view>
        <view class="kpi-item"><view class="kpi-num text-purple">{{kpi.acosPct}}%</view><view class="kpi-label">综合 ACOS</view></view>
      </view>
      <view class="net-line">
        <text class="net-key">≈ 净利</text>
        <text class="net-val {{kpi.netLoss ? 'text-pink' : 'text-green'}}">{{kpi.netText}}</text>
        <text class="net-note">毛利换汇 {{kpi.grossCnyText}} − 公司运营费 {{kpi.opexCnyText}}（FX 6.8;仅全公司层可算）</text>
      </view>
    </view>
  </view>

  <!-- 产品类对比 -->
  <view class="card">
    <view class="card-head">
      <view class="card-title">产品类对比（{{catTotal}} 类）</view>
      <filter-dropdown options="{{catFilters}}" value="{{catFilter}}" bind:change="onCatFilterChange" />
    </view>
    <view class="card-hint">点类展开看整体指标 · 红色为亏损类 · bar 按销售额</view>

    <view wx:if="{{catTotal === 0}}" class="empty-hint">当前筛选下无产品类</view>

    <view
      wx:for="{{categories}}" wx:key="line"
      class="cat {{item.loss ? 'cat-loss' : ''}}">

      <view class="cat-head" data-line="{{item.line}}" bindtap="onCatTap">
        <view class="cat-left">
          <view class="cat-name">{{item.line}}</view>
          <view class="cat-meta">{{item.count}} 个型号</view>
        </view>
        <view class="cat-right">
          <view class="cat-sales">{{item.salesText}}</view>
          <view class="cat-sub {{item.loss ? 'text-pink' : 'text-green'}}">
            毛利 {{item.profitText}} · {{item.marginPct}}%
          </view>
        </view>
        <text class="go-arrow">{{item.expanded ? '▲' : '▼'}}</text>
      </view>

      <view class="cat-bar"><view class="cat-bar-fill" style="width:{{item.barWidth}}%"></view></view>

      <!-- 展开：每产品双进度条(能拿回 vs 要付) -->
      <view wx:if="{{item.expanded}}" class="cat-detail">
        <view class="fb-legend"><text class="fb-dot fb-dot-got"></text>已到账 <text class="fb-dot fb-dot-pend"></text>待回款 <text class="fb-dot fb-dot-owe"></text>要付(欠厂) · 同比例尺</view>
        <view wx:for="{{item.bars}}" wx:for-item="b" wx:key="name" class="fb-prod">
          <view class="fb-name">{{b.name}}</view>
          <!-- 能拿回:已到账(实) + 待回款(斜纹) -->
          <view class="fb-row">
            <view class="fb-track">
              <view class="fb-seg fb-got" style="width:{{b.realizedW}}%"></view>
              <view class="fb-seg fb-pend" style="width:{{b.pendingW}}%"></view>
            </view>
            <text class="fb-val">{{b.recoverText}}</text>
          </view>
          <!-- 要付:欠厂 -->
          <view class="fb-row">
            <view class="fb-track">
              <view wx:if="{{b.hasOwe}}" class="fb-seg fb-owe" style="width:{{b.oweW}}%"></view>
            </view>
            <text class="fb-val {{b.covered ? '' : 'text-pink'}}">{{b.hasOwe ? b.oweText : '—'}}</text>
          </view>
        </view>
        <view wx:if="{{item.bars.length === 0}}" class="empty-hint">该类暂无回款/欠厂数据</view>
        <view class="enter-btn" data-line="{{item.line}}" catchtap="onEnterCategory">进入类看板 ›</view>
      </view>
    </view>

    <view wx:if="{{catTotal > 8}}" class="collapse-toggle" bindtap="onToggleCats">
      {{showAllCats ? '收起 ▲' : '展开全部 ' + catTotal + ' 类 ▼'}}
    </view>
  </view>

  <view class="foot-note">数据：领星销售/回款 + 金蝶财务采购/报销（duoqubao-api 静态快照 {{generatedAt}}）· 盈亏/回款/采购为全期累计 · ⚠️ 款年混算（含 24/25/26 款）</view>
</view>
