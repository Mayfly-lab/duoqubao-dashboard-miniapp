<view class="container">

  <view wx:if="{{loading}}" class="role-hint">加载中…</view>
  <view wx:if="{{error}}" class="role-hint" style="color:#f5455c">{{error}}</view>

  <!-- 待关注（AI 监控）· 老板第一眼 -->
  <view class="card">
    <view class="card-head">
      <view class="card-title">⚠️ 待关注 · {{alertTotal}} 项</view>
      <filter-dropdown options="{{alertFilters}}" value="{{alertFilter}}" bind:change="onAlertFilterChange" />
    </view>
    <view wx:if="{{alertTotal === 0}}" class="empty-hint">当前筛选下无待关注项</view>
    <view wx:for="{{alerts}}" wx:key="index" class="alert-row alert-{{item.level}}" data-name="{{item.name}}" bindtap="onAlertTap">
      <view class="alert-tag alert-tag-{{item.level}}">{{item.tag}}</view>
      <view class="alert-body">
        <text class="alert-name">{{item.name}}</text>
        <text class="alert-msg">{{item.msg}}</text>
      </view>
      <view class="alert-arrow">›</view>
    </view>
    <view wx:if="{{alertTotal > 3}}" class="collapse-toggle" bindtap="onToggleAlerts">
      {{showAllAlerts ? '收起 ▲' : '展开全部 ' + alertTotal + ' 项 ▼'}}
    </view>
  </view>

  <!-- 💵 资金卡:能拿回 vs 欠厂应付线 → 可动用 -->
  <view class="card">
    <view class="board-eyebrow">等钱全收回、欠款全付清,账上大约还剩</view>
    <view class="fc-headline {{fund.deployNeg ? 'text-pink' : 'text-green'}}">{{fund.deployNeg ? '−' : ''}}{{fund.deployText}}<text class="fc-hl-lab">可动用</text></view>

    <view class="fc-lab">钱能拿回 · 最乐观 <text class="fc-b">{{fund.recoverText}}</text></view>
    <view class="fc-bar">
      <view class="fc-seg fc-cash" style="width:{{fund.cashPct}}%" data-seg="cash" bindtap="onFundSeg"><text class="fc-seg-t">现金 {{fund.cashText}}</text></view>
      <view class="fc-seg fc-pend" style="width:{{fund.pendPct}}%" data-seg="pend" bindtap="onFundSeg"><text class="fc-seg-t">待回 {{fund.pendingText}}</text></view>
      <view class="fc-oweline" style="left:{{fund.owePct}}%"><text class="fc-oweline-t">应付线 {{fund.oweText}}</text></view>
    </view>
    <view class="fc-lab2">↑ 越过应付线的部分 = 可动用 · 点条看明细</view>

    <view class="fc-lab">钱要付出去 · 已知应付 <text class="fc-b">{{fund.oweText}}</text></view>
    <view class="fc-bar fc-bar-owe">
      <view class="fc-seg fc-owe" style="width:{{fund.owePct}}%" data-seg="owe" bindtap="onFundSeg"><text class="fc-seg-t">欠供应商 {{fund.oweText}}</text></view>
    </view>

    <view class="fc-health {{fund.healthy ? 'fc-ok' : 'fc-warn'}}">{{fund.healthy ? '✓ 健康:光账上现金就盖得住全部已知应付' : '! 警惕:应付已超过账上现金,现金流吃紧'}}</view>

    <!-- 下钻:现金账户 -->
    <view wx:if="{{fundSeg === 'cash'}}" class="fc-detail">
      <view class="fc-dtitle">账上现金 · {{cashDetail.length}} 账户<text class="fc-dclose" bindtap="onFundClose">收起 ✕</text></view>
      <view wx:for="{{cashDetail}}" wx:key="account" class="fc-drow">
        <text class="fc-dname">{{item.account}} <text class="fc-dtag">{{item.company}}·{{item.ccy}}</text></text>
        <view class="fc-dbar"><view class="fc-dbar-f fc-df-cash" style="width:{{item.pct}}%"></view></view>
        <text class="fc-dval">{{item.cnyText}}</text>
      </view>
    </view>
    <!-- 下钻:欠供应商 → 合同 -->
    <view wx:if="{{fundSeg === 'owe'}}" class="fc-detail">
      <view class="fc-dtitle">欠供应商 · {{oweSuppliers.length}} 家<text class="fc-dclose" bindtap="onFundClose">收起 ✕</text></view>
      <view class="fc-dhint">👇 点供应商看它的合同明细</view>
      <view wx:for="{{oweSuppliers}}" wx:key="supplier" class="fc-sup">
        <view class="fc-drow fc-drow-tap" data-supplier="{{item.supplier}}" bindtap="onSupplierTap">
          <text class="fc-dname">{{item.supplier}}</text>
          <view class="fc-dbar"><view class="fc-dbar-f fc-df-owe" style="width:{{item.pct}}%"></view></view>
          <text class="fc-dval text-pink">{{item.oweText}}</text>
          <text class="fc-dchev">{{expandedSupplier === item.supplier ? '▲' : '合同 ›'}}</text>
        </view>
        <view wx:if="{{expandedSupplier === item.supplier}}" class="fc-contracts">
          <view wx:for="{{item.contracts}}" wx:for-item="c" wx:key="nm" class="fc-crow">
            <text class="fc-cnm">{{c.nm}}</text>
            <text class="fc-camt">采购 {{c.amtText}}</text>
            <text class="fc-cowe text-pink">欠 {{c.oweText}}</text>
          </view>
        </view>
      </view>
    </view>
    <!-- 下钻:待回款 -->
    <view wx:if="{{fundSeg === 'pend'}}" class="fc-detail">
      <view class="fc-dtitle">待回款 {{fund.pendingText}}<text class="fc-dclose" bindtap="onFundClose">收起 ✕</text></view>
      <view class="fc-dnote">平台在途货款,约 2-3 周滚动到账。视界短(只看得到近端),更远的排不出来。</view>
    </view>

    <view class="card-hint">现金/待回/欠厂=真账 · 待回只看平台在途 · 欠厂到期时点不准(合同日期损坏)· 多趣+格致合计 · 快照 {{generatedAt}}</view>
  </view>

  <!-- 📦 库存货值卡 -->
  <view class="card">
    <view class="card-title">📦 库存货值</view>
    <view class="card-hint">钱变成的货现在在哪 · 超 90 天压资金 · 多趣+格致</view>
    <view class="fund-grid">
      <view class="fund-item"><view class="fund-num text-blue">{{inv.goods}}</view><view class="fund-label">货值(在库+在途)</view></view>
      <view class="fund-item"><view class="fund-num">{{inv.xianhuo}}</view><view class="fund-label">现货(件)</view></view>
      <view class="fund-item"><view class="fund-num text-yellow">{{inv.zaitu}}</view><view class="fund-label">在途(件)</view></view>
      <view class="fund-item"><view class="fund-num text-pink">{{inv.staleQty}}</view><view class="fund-label">滞销&gt;90天 · {{inv.stalePct}}%</view></view>
    </view>
    <view class="age-title">滞销 · 超龄 &gt; 90 天 <text class="age-total">{{inv.staleQty}} 件</text></view>
    <view class="age-sub2">颜色越深 = 库龄越久(超 90 天起算)</view>
    <view wx:for="{{inv.staleBars}}" wx:key="label" class="ab-row {{item.warn ? 'ab-warn' : ''}}">
      <text class="ab-lab">{{item.label}}</text>
      <view class="ab-track"><view class="ab-fill {{item.cls}}" style="width:{{item.pct}}%"></view></view>
      <text class="ab-val">{{item.qtyText}}</text>
    </view>
    <view class="age-healthy">✓ 健康 ≤90 天 {{inv.healthyText}} 件 · 深积压 365天+ <text class="text-pink">{{inv.age365Text}} 件</text></view>
  </view>

  <!-- 📊 销售大盘卡 -->
  <view class="card">
    <view class="card-title">📊 销售大盘</view>
    <view class="card-hint">领星真账 · 全期 · 毛利=真实毛利 · 多趣+格致</view>
    <view class="kpi-grid">
      <view class="kpi-item"><view class="kpi-num text-blue">{{sales.salesText}}</view><view class="kpi-label">销售额</view></view>
      <view class="kpi-item"><view class="kpi-num">{{sales.qty}}</view><view class="kpi-label">销量(件)</view></view>
      <view class="kpi-item"><view class="kpi-num text-green">{{sales.marginPct}}%</view><view class="kpi-label">毛利率<text class="real-flag">真实</text></view></view>
      <view class="kpi-item"><view class="kpi-num text-purple">{{sales.tacosPct}}%</view><view class="kpi-label">广告 TAcos</view></view>
    </view>
    <view class="byb-title">按部门拆分</view>
    <view wx:for="{{sales.depts}}" wx:key="name" class="byb-row">
      <text class="byb-name">{{item.name}}</text>
      <text class="byb-sales">{{item.salesText}}</text>
      <text class="byb-margin {{item.loss ? 'text-pink' : 'text-green'}}">毛利率 {{item.marginPct}}%</text>
    </view>
    <view wx:if="{{sales.refundPct}}" class="card-hint">退款率 {{sales.refundPct}}%</view>
  </view>

  <!-- 💸 经营费用 & 净利(精简一行) -->
  <view class="card">
    <view class="card-title">💸 经营费用 & 净利</view>
    <view class="net-line">
      <text class="net-key">运营费</text>
      <text class="net-val">{{opexMod.total}}</text>
      <text class="net-note">{{opexMod.top3}} …(金蝶真账 · 报销待补)</text>
    </view>
    <view class="net-line">
      <text class="net-key">≈ 净利</text>
      <text class="net-val {{kpi.netLoss ? 'text-pink' : 'text-green'}}">{{kpi.netText}}</text>
      <text class="net-note">{{kpi.hasReal ? '真实毛利' : '毛利'}} {{kpi.grossCnyText}} − 运营费 {{kpi.opexCnyText}}(仅全公司层可算)</text>
    </view>
  </view>

  <!-- 产品类对比 -->
  <view class="card">
    <view class="card-head">
      <view class="card-title">产品类对比（{{catTotal}} 类）</view>
      <filter-dropdown options="{{catFilters}}" value="{{catFilter}}" bind:change="onCatFilterChange" />
    </view>
    <view class="card-hint">点类展开看回本明细 · bar 按能收回 · 盈利=能收回−已支付</view>

    <view wx:if="{{catTotal === 0}}" class="empty-hint">当前筛选下无产品类</view>

    <view
      wx:for="{{categories}}" wx:key="line"
      class="cat {{item.loss ? 'cat-loss' : ''}}">

      <view class="cat-head" data-line="{{item.line}}" bindtap="onCatTap">
        <view class="cat-left">
          <view class="cat-name">{{item.line}}</view>
          <view class="cat-meta">{{item.count}} 个型号</view>
        </view>
        <view class="cat-right">
          <view class="cat-sales">能收回 {{item.recoverText}}</view>
          <view class="cat-sub {{item.profitBackLoss ? 'text-pink' : 'text-green'}}">
            盈利 {{item.profitBackText}} <text class="cat-sub2">已付 {{item.paidText}}</text>
          </view>
        </view>
        <text class="go-arrow">{{item.expanded ? '▲' : '▼'}}</text>
      </view>

      <view class="cat-bar"><view class="cat-bar-fill" style="width:{{item.barWidth}}%"></view></view>

      <!-- 展开：每产品回本双条(能收回 vs 已支付)· 重点=盈利(能收回−已支付) -->
      <view wx:if="{{item.expanded}}" class="cat-detail">
        <view class="fb-legend"><text class="fb-dot fb-dot-got"></text>已到账 <text class="fb-dot fb-dot-pend"></text>待回款 <text class="fb-dot fb-dot-paid"></text>已支付 · 盈利=能收回−已支付</view>
        <view wx:for="{{item.bars}}" wx:for-item="b" wx:key="name" class="fb-prod">
          <view class="fb-name">{{b.name}}<text class="fb-back {{b.profitBackLoss ? 'text-pink' : 'text-green'}}">{{b.profitBackText}}</text></view>
          <!-- 能收回:已到账(实) + 待回款 -->
          <view class="fb-row">
            <view class="fb-track">
              <view class="fb-seg fb-got" style="width:{{b.realizedW}}%"></view>
              <view class="fb-seg fb-pend" style="width:{{b.pendingW}}%"></view>
            </view>
            <text class="fb-val">{{b.recoverText}}</text>
          </view>
          <!-- 已支付 -->
          <view class="fb-row">
            <view class="fb-track">
              <view wx:if="{{b.hasPaid}}" class="fb-seg fb-paid" style="width:{{b.paidW}}%"></view>
            </view>
            <text class="fb-val">{{b.hasPaid ? b.paidText : '—'}}</text>
          </view>
        </view>
        <view wx:if="{{item.bars.length === 0}}" class="empty-hint">该类暂无回款/采购数据</view>
        <view class="enter-btn" data-line="{{item.line}}" catchtap="onEnterCategory">进入类看板 ›</view>
      </view>
    </view>

    <view wx:if="{{catTotal > 8}}" class="collapse-toggle" bindtap="onToggleCats">
      {{showAllCats ? '收起 ▲' : '展开全部 ' + catTotal + ' 类 ▼'}}
    </view>
  </view>

  <view class="foot-note">数据：领星销售/回款 + 金蝶财务采购/报销（duoqubao-api 静态快照 {{generatedAt}}）· 盈亏/回款/采购为全期累计 · ⚠️ 款年混算（含 24/25/26 款）</view>
</view>
