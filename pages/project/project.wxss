/* 头部 */
.ph-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.ph-name { font-size: 36rpx; font-weight: 700; color: #eef2fb; }
.ph-team { font-size: 22rpx; color: #94a3c4; border: 1rpx solid #2c3a5c; border-radius: 8rpx; padding: 2rpx 10rpx; margin-left: 14rpx; }
.ph-tag { font-size: 22rpx; padding: 6rpx 18rpx; border-radius: 999rpx; }
.tag-ok { background: rgba(34,196,168,.15); color: #22c4a8; }
.tag-loss { background: rgba(240,98,146,.15); color: #f06292; }

.ph-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.ph-item { width: calc(33.33% - 11rpx); background: #0f1729; border-radius: 16rpx; padding: 20rpx 16rpx; box-sizing: border-box; }
.ph-num { font-size: 32rpx; font-weight: 700; color: #eef2fb; }
.ph-lab { font-size: 20rpx; color: #94a3c4; margin-top: 6rpx; }

/* 趋势柱状 */
.chart { display: flex; align-items: flex-end; justify-content: space-between; height: 240rpx; margin-top: 12rpx; }
.bar-col { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: flex-end; }
.bar { width: 36rpx; background: linear-gradient(180deg, #5b8cff, #3a5fcc); border-radius: 8rpx 8rpx 0 0; }
.bar-profit { font-size: 18rpx; margin-top: 8rpx; }
.bar-date { font-size: 18rpx; color: #6b7280; margin-top: 4rpx; }

/* 员工 */
.owner-row { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid #2c3a5c; }
.owner-row:last-child { border-bottom: none; }
.owner-name { font-size: 28rpx; color: #eef2fb; }
.owner-team { font-size: 20rpx; color: #94a3c4; margin-left: 10rpx; }
.owner-right { text-align: right; }
.owner-contrib { font-size: 24rpx; }
.owner-actions { font-size: 20rpx; color: #6b7280; margin-top: 4rpx; }

/* 费用 */
.cost-row { display: flex; align-items: center; margin-bottom: 14rpx; }
.cost-name { width: 280rpx; font-size: 22rpx; color: #cbd5e1; }
.cost-bar { flex: 1; height: 12rpx; background: #0f1729; border-radius: 6rpx; margin: 0 16rpx; overflow: hidden; }
.cost-bar-fill { height: 100%; background: #f5a524; border-radius: 6rpx; }
.cost-val { width: 130rpx; text-align: right; font-size: 22rpx; color: #f5a524; }

.empty { font-size: 22rpx; color: #6b7280; }
.foot-note { text-align: center; font-size: 20rpx; color: #6b7280; margin-top: 32rpx; }
