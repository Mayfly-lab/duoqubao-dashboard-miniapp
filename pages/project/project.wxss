/* 头部 */
.ph-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.ph-name { font-size: 36rpx; font-weight: 700; color: #1f2a3c; }
.ph-team { font-size: 22rpx; color: #6b7891; border: 1rpx solid #edf0f5; border-radius: 8rpx; padding: 2rpx 10rpx; margin-left: 14rpx; }
.ph-tag { font-size: 22rpx; padding: 6rpx 18rpx; border-radius: 999rpx; }
.tag-ok { background: rgba(34,196,168,.15); color: #18b888; }
.tag-loss { background: rgba(245,69,92,.12); color: #f5455c; }

.ph-grid { display: flex; flex-wrap: wrap; margin: -7rpx; }
.ph-item { flex: 1 1 140rpx; min-width: 140rpx; margin: 7rpx; background: #eef1f6; border: 1rpx solid #edf0f5; border-radius: 16rpx; padding: 22rpx 16rpx; box-sizing: border-box; }
.ph-num { font-size: 32rpx; font-weight: 700; color: #1f2a3c; }
.ph-lab { font-size: 20rpx; color: #6b7891; margin-top: 6rpx; }

/* 趋势柱状 */
.chart { display: flex; align-items: flex-end; justify-content: space-between; height: 240rpx; margin-top: 12rpx; }
.bar-col { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: flex-end; }
.bar { width: 36rpx; background: linear-gradient(180deg, #2b6cff, #3a5fcc); border-radius: 8rpx 8rpx 0 0; }
.bar-profit { font-size: 18rpx; margin-top: 8rpx; }
.bar-date { font-size: 18rpx; color: #9aa6bc; margin-top: 4rpx; }

/* 时间轴(横向滚动·标数字) */
/* 时间轴:横向条形列表(每月一行) */
.tl-row { display: flex; align-items: center; margin-bottom: 12rpx; }
.tl-ym { width: 88rpx; font-size: 20rpx; color: #6b7891; flex-shrink: 0; }
.tl-bar2 { flex: 1; height: 16rpx; background: #eef1f6; border-radius: 8rpx; margin: 0 16rpx; overflow: hidden; }
.tl-fill { height: 100%; background: linear-gradient(90deg, #18b888, #2b6cff); border-radius: 8rpx; }
.tl-fill-neg { background: #f5455c; }
.tl-amt { width: 110rpx; text-align: right; font-size: 20rpx; flex-shrink: 0; }

/* 员工 */
.owner-row { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid #edf0f5; }
.owner-row:last-child { border-bottom: none; }
.owner-name { font-size: 28rpx; color: #1f2a3c; }
.owner-team { font-size: 20rpx; color: #6b7891; margin-left: 10rpx; }
.owner-right { text-align: right; }
.owner-contrib { font-size: 24rpx; }
.owner-actions { font-size: 20rpx; color: #9aa6bc; margin-top: 4rpx; }

/* 费用 */
.cost-row { display: flex; align-items: center; margin-bottom: 14rpx; }
.cost-name { width: 280rpx; font-size: 22rpx; color: #1f2a3c; }
.cost-bar { flex: 1; height: 12rpx; background: #eef1f6; border-radius: 6rpx; margin: 0 16rpx; overflow: hidden; }
.cost-bar-fill { height: 100%; background: #f0a020; border-radius: 6rpx; }
.cost-val { width: 130rpx; text-align: right; font-size: 22rpx; color: #f0a020; }

/* 类中定位 */
.locate { font-size: 22rpx; color: #2b6cff; background: rgba(91,140,255,.1); border-radius: 10rpx; padding: 12rpx 18rpx; margin-bottom: 20rpx; }
/* 费用动作 / 退货原因 复用 cost-row,换色 */
.opex-fill { background: #7c5cff; }
.opex-val { color: #7c5cff; }
.reason-fill { background: #f5455c; }
.reason-val { color: #f5455c; }

.empty { font-size: 22rpx; color: #9aa6bc; }
.foot-note { text-align: center; font-size: 20rpx; color: #9aa6bc; margin-top: 32rpx; }

/* 结算视角:到手 = 销售 − 各项 */
.settle-row { display: flex; align-items: center; gap: 14rpx; padding: 10rpx 0; }
.settle-name { width: 150rpx; font-size: 26rpx; color: #6b7891; flex-shrink: 0; }
.settle-bar { flex: 1; height: 14rpx; background: #edf0f5; border-radius: 7rpx; overflow: hidden; }
.settle-bar-fill { height: 100%; background: #f5455c; border-radius: 7rpx; }
.settle-val { width: 150rpx; text-align: right; font-size: 26rpx; flex-shrink: 0; }
.settle-top { border-bottom: 1rpx solid rgba(255,255,255,.08); }
.settle-net { margin-top: 6rpx; border-top: 1rpx solid rgba(255,255,255,.12); font-weight: 700; }
.settle-net .settle-name, .settle-net .settle-val { font-size: 30rpx; }
