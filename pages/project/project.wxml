<view class="container">

  <view class="demo-banner">毛利为 <text class="text-green">真实毛利</text>（全期·合同成本修正,与类页/财务一致）</view>

  <view wx:if="{{loading}}" class="card">加载中…</view>
  <view wx:if="{{error}}" class="card" style="color:#f5455c">{{error}}</view>

  <block wx:if="{{proj}}">
  <!-- 💰 回本双条(能收回 vs 已支付)· 最前 -->
  <view wx:if="{{payback0}}" class="card">
    <view class="card-title">💰 回本情况</view>
    <view class="rb-lab">能收回 <text class="rb-b text-green">{{payback0.recoverText}}</text><text class="rb-sub">已到账 {{payback0.realizedText}} + 待回款 {{payback0.pendingText}} · 点条看明细</text></view>
    <view class="rb-track" data-seg="recover" bindtap="onRbSeg">
      <view class="rb-seg rb-got" style="width:{{payback0.realizedW}}%"></view>
      <view class="rb-seg rb-pend" style="width:{{payback0.pendingW}}%"></view>
    </view>
    <view class="rb-lab">已支付 <text class="rb-b">{{payback0.paidText}}</text><text class="rb-sub">采购已付现金(投入)· 点条看明细</text></view>
    <view class="rb-track" data-seg="paid" bindtap="onRbSeg">
      <view class="rb-seg rb-paid" style="width:{{payback0.paidW}}%"></view>
    </view>
    <view wx:if="{{payback0.hasPaid}}" class="rb-verdict {{payback0.recovered ? 'rb-ok' : 'rb-warn'}}">{{payback0.recovered ? '✓ 已回本:能收回 ≥ 已支付' : '⚠️ 已支付 > 能收回,回款慢/考虑换品止损'}}</view>
    <view wx:else class="card-hint">该型号已支付串不到金蝶合同(规范名只到类级)· 见类页回本</view>
    <!-- 点条明细 -->
    <view wx:if="{{rbSeg === 'recover'}}" class="rb-detail">
      <view class="rb-dt">能收回明细</view>
      <view class="rb-drow"><text class="rb-dnm">已到账(真金)</text><text class="rb-dv text-green">{{payback0.realizedText}}</text></view>
      <view class="rb-drow"><text class="rb-dnm">待回款(在路上)</text><text class="rb-dv text-yellow">{{payback0.pendingText}}</text></view>
    </view>
    <view wx:if="{{rbSeg === 'paid'}}" class="rb-detail">
      <view class="rb-dt">已支付明细 · 采购</view>
      <block wx:if="{{procurement}}">
        <view class="rb-drow"><text class="rb-dnm">采购总额</text><text class="rb-dv">{{procurement.amountText}}</text></view>
        <view class="rb-drow"><text class="rb-dnm">已付</text><text class="rb-dv">{{procurement.paidText}}</text></view>
        <view class="rb-drow"><text class="rb-dnm">欠厂未付</text><text class="rb-dv text-pink">{{procurement.oweText}}</text></view>
      </block>
      <view wx:else class="card-hint">该型号采购串不到金蝶合同(规范名只到类级)</view>
    </view>
  </view>

  <!-- 头部指标(销售/真实毛利/ACOS) -->
  <view class="card">
    <view class="ph-top">
      <view class="ph-name">{{name}}<text class="ph-team">{{proj.team}}</text></view>
      <view class="ph-tag {{proj.loss ? 'tag-loss' : 'tag-ok'}}">{{proj.loss ? '亏损' : '盈利'}}</view>
    </view>
    <view wx:if="{{locate}}" class="locate">{{locate.line}} 类 · 销售第 {{locate.rank}}/{{locate.total}} · 占类 {{locate.share}}%</view>
    <view class="ph-grid">
      <view class="ph-item"><view class="ph-num text-blue">{{proj.salesText}}</view><view class="ph-lab">销售额</view></view>
      <view class="ph-item"><view class="ph-num {{proj.loss ? 'text-pink' : 'text-green'}}">{{proj.profitText}}</view><view class="ph-lab">毛利<text wx:if="{{realProfit}}" class="real-flag">真实</text></view></view>
      <view class="ph-item"><view class="ph-num text-yellow">{{proj.margin_pct}}%</view><view class="ph-lab">毛利率<text wx:if="{{realProfit}}" class="real-flag">真实</text></view></view>
      <view class="ph-item"><view class="ph-num text-purple">{{proj.acos_pct}}%</view><view class="ph-lab">ACOS</view></view>
      <view class="ph-item"><view class="ph-num">{{proj.adCostText}}</view><view class="ph-lab">广告费</view></view>
    </view>
    <view wx:if="{{realProfit}}" class="card-hint">领星原报毛利率 {{realProfit.lxMarginPct}}%(常漏填成本→虚高)。真实毛利 = 领星毛利 − (销量×合同采购单价 − 领星填的成本)。合同单价 ¥{{realProfit.unitCny}}/件(类级估算)· 未扣海运。</view>
  </view>

  <!-- 📦 库存 -->
  <view wx:if="{{inventory}}" class="card">
    <view class="card-title">📦 库存</view>
    <view class="ph-grid">
      <view class="ph-item"><view class="ph-num text-blue">{{inventory.xianhuo}}</view><view class="ph-lab">现货</view></view>
      <view class="ph-item"><view class="ph-num text-yellow">{{inventory.zaitu}}</view><view class="ph-lab">在途</view></view>
      <view class="ph-item"><view class="ph-num">{{inventory.fbaTotal}}</view><view class="ph-lab">FBA 合计</view></view>
    </view>
  </view>

  <!-- 负责员工 -->
  <view class="card">
    <view class="card-title">负责员工</view>
    <view wx:for="{{owners}}" wx:key="name" class="owner-row">
      <view class="owner-name">{{item.name}}<text class="owner-team">{{item.team}} · {{item.tag}}</text></view>
    </view>
    <view wx:if="{{owners.length === 0}}" class="empty">未在 registry 找到归属</view>
  </view>
  </block>

  <view class="foot-note">领星 + 金蝶财务(快照 {{generatedAt}})· 盈亏/回款全期累计</view>
</view>
